# Core
NODE_ENV=development
PORT=3000
BASE_DOMAIN=is.am

# Session (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Database
DB_TYPE=sqlite
SQLITE_PATH=./data/isam.db

# MySQL/MariaDB (used when DB_TYPE=mysql)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=isam
# MYSQL_PASSWORD=secret
# MYSQL_DATABASE=isam

# DNS Server
DNS_ENABLED=true
DNS_PORT=5300
DNS_UPSTREAM=8.8.8.8
# Subdomain used for NS-delegated dynamic DNS (records resolve as NAME.DYN_SUBDOMAIN.DOMAIN)
DYN_SUBDOMAIN=dyn

# Branding
SITE_NAME=is.am
SITE_TAGLINE=Shorten. Share. Track.
SITE_LOGO_PATH=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Theme (folder name inside src/themes/, defaults to 'default')
THEME=default

# Shortlinks
# Character set used to encode short codes (case-insensitive, lowercase only recommended)
# Fewer chars = longer codes. More chars = shorter codes.
SHORTLINK_CHARS=abcdefghijklmnopqrstuvwxyz0123456789

# Uploads
# Maximum image upload size in bytes (default: 10MB)
IMAGE_MAX_BYTES=10485760

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_CREATION_MAX=10
RATE_LIMIT_CREATION_WINDOW_MS=60000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_MS=600000
ANON_TOKEN_COOKIE_DAYS=30
