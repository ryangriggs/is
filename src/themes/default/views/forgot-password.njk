{% extends "layouts/base.njk" %}
{% block title %}Forgot Password — {{ siteName }}{% endblock %}
{% block content %}
<div class="auth-wrap">
  <div class="auth-card">
    <h1 class="auth-title">Reset password</h1>
    <p class="auth-subtitle">Enter your email and we'll send a reset link.</p>

    <form method="POST" action="/forgot-password">
      <div class="form-group">
        <label class="label" for="email">Email Address</label>
        <input id="email" type="email" name="email" class="input"
          required autocomplete="email" autofocus>
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Send Reset Link</button>
    </form>

    <p class="text-center text-sm text-muted mt-3">
      <a href="/login">← Back to login</a>
    </p>
  </div>
</div>
{% endblock %}
