{% extends "layouts/base.njk" %}

{% block title %}Protected Link — {{ siteName }}{% endblock %}

{% block content %}
<div class="auth-wrap">
  <div class="auth-card">
    <h1 class="auth-title">Password Required</h1>
    <p class="auth-subtitle">This link is password-protected. Enter the password to continue.</p>

    {% if error %}
    <div class="alert alert-error mb-3">{{ error }}</div>
    {% endif %}

    <form method="GET">
      <div class="form-group">
        <label class="label" for="password">Password</label>
        <input
          id="password"
          type="password"
          name="p"
          class="input"
          required
          autofocus
          autocomplete="off"
        >
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Continue</button>
    </form>
  </div>
</div>
{% endblock %}
