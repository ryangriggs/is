{% extends "layouts/base.njk" %}

{% block title %}{{ siteName }} — {{ siteTagline }}{% endblock %}

{% block content %}
<section class="hero">
  <div class="container">
    <h1 class="hero-title gradient-text">{{ siteTagline or "Shorten. Share. Track." }}</h1>
    <p class="hero-subtitle">{{ siteHeroSubtitle or "The fastest way to shorten URLs, share files, and manage your links." }}</p>

    <form id="hero-form" method="POST" action="/" style="max-width:600px;margin:0 auto 32px">
      <div aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;overflow:hidden">
        <label for="hp-website">Website</label>
        <input type="text" id="hp-website" name="website" value="" tabindex="-1" autocomplete="off">
      </div>
      <div style="display:flex;gap:8px">
        <input
          id="hero-url"
          type="url"
          name="destination"
          class="input hero-form-input"
          value="https://"
          required
          autocomplete="off"
          autofocus
        >
        <button type="submit" class="btn btn-primary" style="padding:14px 28px;font-size:1rem;white-space:nowrap">Shorten</button>
      </div>
      <div style="margin-top:.5rem">
        <button type="button" id="url-opts-toggle" class="btn btn-ghost btn-sm" style="font-size:.8rem;padding:.2rem .6rem">
          ⚙ Options
        </button>
        <div id="url-opts" style="display:none;margin-top:.5rem;padding:.75rem;background:var(--bg-card);border:1px solid var(--color-border);border-radius:var(--radius-lg);flex-direction:column;gap:.5rem">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.875rem">
            <input type="checkbox" name="burn_on_read" value="1"> 🔥 Burn on read (one-time link)
          </label>
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.875rem;flex-wrap:wrap">
            <span>⏰ Expires:</span>
            <input type="datetime-local" name="expires_at" id="url-expires" class="input" style="flex:1;min-width:180px;max-width:260px">
            <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('url-expires').value=''">Clear</button>
          </label>
        </div>
      </div>
    </form>
    <script>
    (function(){
      var btn = document.getElementById('url-opts-toggle')
      var panel = document.getElementById('url-opts')
      var input = document.getElementById('hero-url')
      var open = false

      btn.addEventListener('click', function(){
        open = !open
        panel.style.display = open ? 'flex' : 'none'
        panel.style.flexDirection = 'column'
        btn.textContent = open ? '⚙ Options ▲' : '⚙ Options'
      })

      // Keep cursor after https:// when user focuses on an unchanged prefill
      input.addEventListener('focus', function(){
        if (this.value === 'https://') {
          var el = this
          setTimeout(function(){ el.setSelectionRange(8, 8) }, 0)
        }
      })

      // Clear just the prefix if user hasn't typed anything and submits blank
      input.form.addEventListener('submit', function(){
        if (input.value === 'https://') input.value = ''
      })
    })()
    </script>

    <div class="hero-features">
      <a href="/t" class="btn-feature"><span class="feat-icon">📝</span> Text Paste</a>
      <a href="/h" class="btn-feature"><span class="feat-icon">🌐</span> HTML Paste</a>
      <a href="/i" class="btn-feature"><span class="feat-icon">🖼️</span> Image Upload</a>
      <a href="/b" class="btn-feature"><span class="feat-icon">🔖</span> Bookmarks</a>
      <a href="https://yourddns.com" target="_blank" rel="noopener" class="btn-feature"><span class="feat-icon">🌍</span> Dynamic DNS ↗</a>
      <a href="/q" class="btn-feature"><span class="feat-icon">⬛</span> QR Codes</a>
    </div>
    {% include "partials/ad-banner.njk" %}
  </div>
</section>

<section class="section">
  <div class="container">
    {% if stats %}
    <div class="stats-grid mb-4">
      {% if stats.showLinks %}
      <div class="stat-card">
        <div class="stat-value">{{ stats.totalLinks | default(0) }}</div>
        <div class="stat-label">Links Created</div>
      </div>
      {% endif %}
      {% if stats.showVisits %}
      <div class="stat-card">
        <div class="stat-value">{{ stats.totalVisits | default(0) }}</div>
        <div class="stat-label">Total Visits</div>
      </div>
      {% endif %}
      {% if stats.showUsers %}
      <div class="stat-card">
        <div class="stat-value">{{ stats.totalUsers | default(0) }}</div>
        <div class="stat-label">Users</div>
      </div>
      {% endif %}
    </div>
    {% endif %}

    <h2 class="section-title">Everything you need</h2>
    <p class="section-subtitle">Powerful tools, one domain.</p>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🔗</div>
        <div class="feature-title">URL Shortener</div>
        <div class="feature-desc">Create short links instantly. No account needed. Custom codes for registered users.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <div class="feature-title">Link Analytics</div>
        <div class="feature-desc">Track visits, referrers, and geographic data for every link you create.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📋</div>
        <div class="feature-title">Pastebins</div>
        <div class="feature-desc">Share text, HTML, and images with a single short link. Supports syntax highlighting.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔖</div>
        <div class="feature-title">Bookmarks</div>
        <div class="feature-desc">Save and organize your bookmarks. Create shareable bookmark collections.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌍</div>
        <div class="feature-title">Dynamic DNS</div>
        <div class="feature-desc">Get a custom subdomain that follows your dynamic IP. Perfect for home servers.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⬛</div>
        <div class="feature-title">QR Codes</div>
        <div class="feature-desc">Generate high-resolution QR codes for any URL. Download for print.</div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
