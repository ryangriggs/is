{% extends "layouts/base.njk" %}

{% block title %}{{ siteName }} — {{ siteTagline }}{% endblock %}

{% block content %}
<section class="hero">
  <div class="container">
    <h1 class="hero-title gradient-text">{{ siteTagline or "Shorten. Share. Track." }}</h1>
    <p class="hero-subtitle">{{ siteHeroSubtitle or "The fastest way to shorten URLs, share files, and manage your links." }}</p>

    <form id="hero-form" method="POST" action="/" class="hero-form">
      <div aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;overflow:hidden">
        <label for="hp-website">Website</label>
        <input type="text" id="hp-website" name="website" value="" tabindex="-1" autocomplete="off">
      </div>
      <input
        id="hero-url"
        type="url"
        name="destination"
        class="input"
        placeholder="https://your-long-url.com/paste-here"
        required
        autocomplete="off"
        autofocus
      >
      <button type="submit" class="btn btn-primary">Shorten</button>
    </form>

    <div class="hero-features">
      <a href="/t" class="btn-feature"><span class="feat-icon">📝</span> Text Paste</a>
      <a href="/h" class="btn-feature"><span class="feat-icon">🌐</span> HTML Paste</a>
      <a href="/i" class="btn-feature"><span class="feat-icon">🖼️</span> Image Upload</a>
      <a href="/b" class="btn-feature"><span class="feat-icon">🔖</span> Bookmarks</a>
      <a href="/d" class="btn-feature"><span class="feat-icon">🌍</span> Dynamic DNS</a>
      <a href="/q" class="btn-feature"><span class="feat-icon">⬛</span> QR Codes</a>
    </div>
    {% include "partials/ad-banner.njk" %}
  </div>
</section>

<section class="section">
  <div class="container">
    {% if stats %}
    <div class="stats-grid mb-4">
      {% if stats.showLinks %}
      <div class="stat-card">
        <div class="stat-value">{{ stats.totalLinks | default(0) }}</div>
        <div class="stat-label">Links Created</div>
      </div>
      {% endif %}
      {% if stats.showVisits %}
      <div class="stat-card">
        <div class="stat-value">{{ stats.totalVisits | default(0) }}</div>
        <div class="stat-label">Total Visits</div>
      </div>
      {% endif %}
      {% if stats.showUsers %}
      <div class="stat-card">
        <div class="stat-value">{{ stats.totalUsers | default(0) }}</div>
        <div class="stat-label">Users</div>
      </div>
      {% endif %}
    </div>
    {% endif %}

    <h2 class="section-title">Everything you need</h2>
    <p class="section-subtitle">Powerful tools, one domain.</p>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🔗</div>
        <div class="feature-title">URL Shortener</div>
        <div class="feature-desc">Create short links instantly. No account needed. Custom codes for registered users.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <div class="feature-title">Link Analytics</div>
        <div class="feature-desc">Track visits, referrers, and geographic data for every link you create.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📋</div>
        <div class="feature-title">Pastebins</div>
        <div class="feature-desc">Share text, HTML, and images with a single short link. Supports syntax highlighting.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔖</div>
        <div class="feature-title">Bookmarks</div>
        <div class="feature-desc">Save and organize your bookmarks. Create shareable bookmark collections.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌍</div>
        <div class="feature-title">Dynamic DNS</div>
        <div class="feature-desc">Get a custom subdomain that follows your dynamic IP. Perfect for home servers.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⬛</div>
        <div class="feature-title">QR Codes</div>
        <div class="feature-desc">Generate high-resolution QR codes for any URL. Download for print.</div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
