{% extends "layouts/base.njk" %}
{% block title %}Log In — {{ siteName }}{% endblock %}
{% block content %}
{% include "partials/ad-banner.njk" %}
<div class="auth-wrap">
  <div class="auth-card">
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Log in to manage your links.</p>

    {% if googleOnlyEmail %}
    <div class="alert alert-info mb-3">
      This account was created with Google Sign-In. Use the button below, or <a href="/forgot-password">set a password</a> to enable email login.
    </div>
    <a href="/auth/google" class="btn btn-google btn-block btn-lg mb-3">
      <svg width="18" height="18" viewBox="0 0 18 18" style="vertical-align:middle;margin-right:.5rem" aria-hidden="true"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z"/></svg>
      Continue with Google
    </a>
    {% elif unverifiedEmail %}
    <div class="alert alert-warning mb-3">
      Please verify your email address before logging in.
    </div>
    <form method="POST" action="/resend-verification" class="mb-3">
      <input type="hidden" name="email" value="{{ unverifiedEmail }}">
      <button type="submit" class="btn btn-secondary btn-block">Resend verification email</button>
    </form>
    {% elif error %}
    <div class="alert alert-error mb-3">{{ error }}</div>
    {% endif %}

    {% if not googleOnlyEmail %}
    <a href="/auth/google" class="btn btn-google btn-block btn-lg">
      <svg width="18" height="18" viewBox="0 0 18 18" style="vertical-align:middle;margin-right:.5rem" aria-hidden="true"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z"/></svg>
      Continue with Google
    </a>

    <div class="auth-divider"><span>or</span></div>

    <form method="POST" action="/login">
      {% if next %}
      <input type="hidden" name="next" value="{{ next }}">
      {% endif %}
      <div class="form-group">
        <label class="label" for="login">Email Address</label>
        <input id="login" type="text" name="login" class="input"
          value="{{ prefill }}" required autocomplete="email" autofocus>
      </div>
      <div class="form-group">
        <label class="label" for="password">Password</label>
        <input id="password" type="password" name="password" class="input"
          required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Log In</button>
    </form>

    <p class="text-center text-sm text-muted mt-3">
      <a href="/forgot-password">Forgot password?</a>
    </p>
    <p class="text-center text-sm text-muted mt-1">
      Don't have an account? <a href="/register">Sign up free</a>
    </p>
    {% endif %}
  </div>
</div>
{% endblock %}
