{% extends "layouts/base.njk" %}
{% block title %}Dashboard — {{ siteName }}{% endblock %}

{% block head %}
<style>
  .img-text-link { font-size:.8rem; }
  #dash-tbody.show-images .img-text-link { display:none; }
</style>
{% endblock %}

{% block content %}
<div class="container">
  <div class="page-header">
    <div>
      <h1 class="page-title">Dashboard</h1>
      <p class="page-subtitle">Welcome back, <strong>{{ user.displayName or user.email or user.username }}</strong></p>
    </div>
    <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
      <div class="dropdown">
        <button class="btn btn-primary dropdown-toggle">+ New ▾</button>
        <div class="dropdown-menu">
          <a href="/" class="dropdown-item">🔗 URL Shortlink</a>
          <a href="/t" class="dropdown-item">📝 Text Paste</a>
          <a href="/h" class="dropdown-item">🌐 HTML Paste</a>
          <a href="/i" class="dropdown-item">🖼️ Image Upload</a>
          <a href="/b" class="dropdown-item">🔖 Bookmark Collection</a>
          <a href="/q" class="dropdown-item">⬛ QR Code</a>
          <a href="https://yourddns.com" target="_blank" rel="noopener" class="dropdown-item">🌍 Dynamic DNS ↗</a>
        </div>
      </div>
    </div>
  </div>

  {% include "partials/ad-banner.njk" %}
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value">{{ stats.totalLinks }}</div>
      <div class="stat-label">My Links</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{ stats.totalVisits }}</div>
      <div class="stat-label">Total Visits</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{ stats.visitsToday }}</div>
      <div class="stat-label">Visits Today</div>
    </div>
  </div>

  {% if links.length == 0 %}
  <div class="card text-center" style="padding:48px;">
    <div style="font-size:3rem;margin-bottom:16px;">🔗</div>
    <h3 class="card-title">No links yet</h3>
    <p class="card-body mb-3">Create your first short link to get started.</p>
    <a href="/" class="btn btn-primary">Create a link</a>
  </div>
  {% else %}

  {# Filter bar #}
  <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:.75rem">
    <div class="type-pills" id="dash-type-pills">
      <button type="button" class="type-pill active" data-type="all">All</button>
      <button type="button" class="type-pill" data-type="url">URL</button>
      <button type="button" class="type-pill" data-type="text">Text</button>
      <button type="button" class="type-pill" data-type="html">HTML</button>
      <button type="button" class="type-pill" data-type="image">Image</button>
      <button type="button" class="type-pill" data-type="bookmark">Bookmark</button>
    </div>
    <div style="display:flex;align-items:center;gap:.4rem;margin-left:auto">
      <span style="font-size:.8rem;color:var(--color-text-muted)">Images</span>
      <label class="slide-toggle" style="cursor:pointer" title="Show image thumbnails">
        <input type="checkbox" id="dash-img-toggle">
        <span class="slide-knob"></span>
      </label>
    </div>
  </div>

  <div class="table-wrap">
    <table id="dash-table">
      <thead>
        <tr>
          {% macro sth(label, col) %}
          <th>
            <a href="?sort={{ col }}&dir={{ 'desc' if (sort == col and dir == 'asc') else 'asc' }}&page=1"
               style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:3px;user-select:none">
              {{ label }}<span style="font-size:.7rem;opacity:{% if sort == col %}1{% else %}.4{% endif %};color:var(--color-primary)">
                {% if sort == col %}{{ '↓' if dir == 'desc' else '↑' }}{% else %}↕{% endif %}
              </span>
            </a>
          </th>
          {% endmacro %}
          {{ sth('Short Link', 'code') }}
          {{ sth('Type', 'type') }}
          <th>Title / Destination</th>
          {{ sth('Created', 'created_at') }}
          {{ sth('Visits', 'visit_count') }}
          {{ sth('Status', 'is_active') }}
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="dash-tbody">
        {% for link in links %}
        <tr data-type="{{ link.type }}">
          <td class="td-code">
            <a href="https://{{ baseDomain }}/{{ link.code }}" target="_blank" rel="noopener">
              {{ baseDomain }}/{{ link.code }}
            </a>
          </td>
          <td>
            <span class="badge badge-info">
              {% if link.type == 'url' %}URL
              {% elif link.type == 'text' %}Text
              {% elif link.type == 'html' %}HTML
              {% elif link.type == 'image' %}Image
              {% elif link.type == 'bookmark' %}Collection
              {% else %}{{ link.type }}{% endif %}
            </span>
          </td>
          <td class="td-url">
            {% if link.type == 'image' %}
              <a href="/uploads/{{ link.destination }}" target="_blank" rel="noopener">
                <img class="link-thumb" src="/uploads/{{ link.destination }}" alt="">
              </a>
              <a href="/uploads/{{ link.destination }}" target="_blank" rel="noopener" class="img-text-link">View image ↗</a>
            {% elif link.type == 'url' %}
              <a href="{{ link.destination }}" target="_blank" rel="noopener nofollow"
                 title="{{ link.destination }}" style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;vertical-align:middle">
                ↗ {{ link.destination | truncate(50) }}
              </a>
            {% else %}
              <span class="text-muted text-sm">{{ link.title or '—' }}</span>
            {% endif %}
          </td>
          <td class="text-muted text-sm">{{ link.createdAt | date }}</td>
          <td>{{ link.visitCount or 0 }}</td>
          <td>
            {% if link.isActive %}
              <span class="badge badge-success">Active</span>
            {% else %}
              <span class="badge badge-danger">Inactive</span>
            {% endif %}
          </td>
          <td class="td-actions">
            <div class="td-actions-inner">
              <button class="btn btn-ghost btn-sm" data-copy="https://{{ baseDomain }}/{{ link.code }}" title="Copy">📋</button>
              <a href="/q?url=https://{{ baseDomain }}/{{ link.code }}" class="btn btn-ghost btn-sm" title="QR Code"><svg width="14" height="14" viewBox="0 0 10 10" fill="currentColor" style="display:inline-block;vertical-align:middle"><rect x="0" y="0" width="4" height="4"/><rect x="1" y="1" width="2" height="2" fill="var(--bg-card,#fff)"/><rect x="6" y="0" width="4" height="4"/><rect x="7" y="1" width="2" height="2" fill="var(--bg-card,#fff)"/><rect x="0" y="6" width="4" height="4"/><rect x="1" y="7" width="2" height="2" fill="var(--bg-card,#fff)"/><rect x="6" y="6" width="2" height="2"/><rect x="8" y="8" width="2" height="2"/></svg></a>
              <a href="/dashboard/edit/{{ link.id }}" class="btn btn-secondary btn-sm" title="Edit">✏️</a>
              <form method="POST" action="/dashboard/delete/{{ link.id }}" style="display:inline">
                <button type="submit" class="btn btn-danger btn-sm" data-confirm="Delete this link?" title="Delete">🗑</button>
              </form>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <script>
  (function() {
    function getCookie(k) { const m = document.cookie.match('(?:^|;)\\s*' + k + '=([^;]*)'); return m ? decodeURIComponent(m[1]) : null }
    function setCookie(k, v) { const d = new Date(); d.setTime(d.getTime() + 365*86400000); document.cookie = k+'='+encodeURIComponent(v)+';expires='+d.toUTCString()+';path=/' }

    const tbody = document.getElementById('dash-tbody')
    const allRows = Array.from(document.querySelectorAll('#dash-tbody tr[data-type]'))

    // Images toggle
    const imgToggle = document.getElementById('dash-img-toggle')
    if (imgToggle && tbody) {
      imgToggle.checked = getCookie('dash_images') === '1'
      if (imgToggle.checked) tbody.classList.add('show-images')
      imgToggle.addEventListener('change', () => {
        tbody.classList.toggle('show-images', imgToggle.checked)
        setCookie('dash_images', imgToggle.checked ? '1' : '0')
      })
    }

    // Type filter pills
    const pills = document.querySelectorAll('#dash-type-pills .type-pill')
    let activeTypes = new Set(JSON.parse(getCookie('dash_types') || '["all"]'))
    function applyFilter() {
      const showAll = activeTypes.has('all') || activeTypes.size === 0
      allRows.forEach(r => { r.style.display = showAll || activeTypes.has(r.dataset.type) ? '' : 'none' })
      pills.forEach(p => p.classList.toggle('active', activeTypes.has(p.dataset.type)))
      setCookie('dash_types', JSON.stringify([...activeTypes]))
    }
    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const t = pill.dataset.type
        if (t === 'all') { activeTypes = new Set(['all']) }
        else {
          activeTypes.delete('all')
          activeTypes.has(t) ? activeTypes.delete(t) : activeTypes.add(t)
          if (activeTypes.size === 0) activeTypes.add('all')
        }
        applyFilter()
      })
    })
    applyFilter()
  })()
  </script>

  {% if pagination.totalPages > 1 %}
  <div class="pagination">
    {% if pagination.page > 1 %}
      <a href="?page={{ pagination.page - 1 }}">‹ Prev</a>
    {% else %}
      <span class="disabled">‹ Prev</span>
    {% endif %}

    {% for p in range(1, pagination.totalPages + 1) %}
      {% if p == pagination.page %}
        <span class="active">{{ p }}</span>
      {% else %}
        <a href="?page={{ p }}">{{ p }}</a>
      {% endif %}
    {% endfor %}

    {% if pagination.page < pagination.totalPages %}
      <a href="?page={{ pagination.page + 1 }}">Next ›</a>
    {% else %}
      <span class="disabled">Next ›</span>
    {% endif %}
  </div>
  {% endif %}
  {% endif %}

</div>
{% endblock %}
