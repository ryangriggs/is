{% if ad %}
<div style="max-width:728px;margin:1rem auto .5rem;padding:.6rem .75rem .75rem;background:var(--bg-card);border-radius:var(--radius-lg);border:1px solid var(--color-border)">
  <div style="font-size:.6rem;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-dim);margin-bottom:.4rem;text-align:center">Advertisement</div>
  <a href="{{ ad.clickUrl }}" target="_blank" rel="noopener nofollow sponsored"
     style="display:flex;align-items:center;justify-content:center;height:{{ adImageHeight or '90' }}px;overflow:hidden;border-radius:4px">
    <img src="{{ ad.imageUrl }}" alt="Advertisement"
         style="max-width:100%;height:100%;object-fit:contain;display:block">
  </a>
</div>
{% endif %}
