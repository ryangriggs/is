{% extends "layouts/base.njk" %}
{% block title %}{{ link.title or 'HTML Paste' }} — {{ siteName }}{% endblock %}
{% block content %}
<section class="section">
  <div class="container">
    {% include "partials/ad-banner.njk" %}
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1rem">
      <div>
        <h1 style="margin:0;font-size:1.25rem">{{ link.title or 'HTML Paste' }}</h1>
        <p class="text-muted text-sm" style="margin:.25rem 0 0">
          {{ link.created_at | date }} &bull;
          <a href="/report/{{ link.code }}" class="text-muted">Report</a>
        </p>
      </div>
      <div style="display:flex;gap:.5rem">
        <a href="/{{ link.code }}/raw" class="btn btn-ghost btn-sm" target="_blank">↗ Raw / Embed</a>
        <a href="/h" class="btn btn-ghost btn-sm">+ New paste</a>
      </div>
    </div>

    <div class="card" style="padding:0;overflow:hidden">
      <iframe
        id="html-frame"
        sandbox="allow-scripts allow-same-origin"
        style="width:100%;min-height:500px;border:none;display:block"
        srcdoc="{{ link.destination | escape }}"
      ></iframe>
    </div>
  </div>
</section>
{% endblock %}
{% block scripts %}
<script>
  const frame = document.getElementById('html-frame')
  frame.addEventListener('load', () => {
    try { frame.style.height = frame.contentDocument.body.scrollHeight + 'px' } catch (_) {}
  })
</script>
{% endblock %}
