{% extends "layouts/base.njk" %}
{% block title %}Account Tiers — Admin — {{ siteName }}{% endblock %}

{% block content %}
<div class="container">
  <div class="page-header">
    <div>
      <h1 class="page-title">Account Tiers</h1>
      <p class="page-subtitle">Configure subscription levels shown on the <a href="/pricing">/pricing</a> page</p>
    </div>
    <a href="/admin" class="btn btn-ghost btn-sm">← Admin</a>
  </div>

  {% if tiers.length == 0 %}
  <div class="card text-center text-muted" style="padding:2rem">No tiers configured.</div>
  {% endif %}

  {% for tier in tiers %}
  <div class="card mb-3" style="{% if not tier.is_enabled %}opacity:.6{% endif %}">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:{% if tier.name == 'anonymous' %}.5{% else %}1{% endif %}rem;flex-wrap:wrap;gap:.5rem">
      <div style="display:flex;align-items:center;gap:.75rem">
        <h3 style="margin:0;text-transform:capitalize">{{ tier.label or tier.name }}</h3>
        {% if tier.name != 'anonymous' %}
          {% if tier.is_enabled %}
            <span class="badge badge-success">Enabled</span>
          {% else %}
            <span class="badge badge-neutral">Disabled</span>
          {% endif %}
        {% endif %}
        {% if tier.price > 0 %}
          <span class="badge badge-info">${{ tier.price }}/mo</span>
        {% else %}
          <span class="badge badge-neutral">Free</span>
        {% endif %}
      </div>
      <div style="display:flex;gap:.5rem;align-items:center">
        {% if tier.name == 'anonymous' %}
          <span class="badge badge-neutral" title="Applies to visitors who are not logged in. Limits are tracked per IP address.">Built-in · IP-based</span>
        {% else %}
          <form method="POST" action="/admin/account-tiers/{{ tier.id }}/toggle-enabled" style="display:inline">
            <button class="btn btn-ghost btn-sm">{{ 'Disable' if tier.is_enabled else 'Enable' }}</button>
          </form>
          <form method="POST" action="/admin/account-tiers/{{ tier.id }}/delete" style="display:inline">
            <button class="btn btn-danger btn-sm" data-confirm="Delete tier '{{ tier.name }}'?">Delete</button>
          </form>
        {% endif %}
      </div>
    </div>

    {% if tier.name == 'anonymous' %}
    <p class="text-sm text-muted" style="margin:0 0 1rem">Applies to visitors who are <strong>not logged in</strong>. Limits are enforced per IP address. DDNS is not available to anonymous users.</p>
    {% endif %}
    <form method="POST" action="/admin/account-tiers">
      <input type="hidden" name="name" value="{{ tier.name }}">

      <div class="form-group">
        <label class="label">Display Label</label>
        <input type="text" name="label" class="input" value="{{ tier.label or tier.name }}">
      </div>
      <div class="form-group">
        <label class="label">Description <span class="text-muted" style="font-weight:400">(shown on pricing page)</span></label>
        <textarea name="description" class="input" rows="2" placeholder="What's included in this plan...">{{ tier.description or '' }}</textarea>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;margin-bottom:1rem">
        <div>
          <label class="label">Price ($/month, 0 = free)</label>
          <input type="number" name="price" class="input" value="{{ tier.price or 0 }}" min="0" step="0.01">
        </div>
        <div>
          <label class="label">Price ($/year, 0 = same as monthly)</label>
          <input type="number" name="price_yearly" class="input" value="{{ tier.price_yearly or 0 }}" min="0" step="0.01">
        </div>
        <div>
          <label class="label">Stripe Price ID (monthly)</label>
          <input type="text" name="stripe_price_id_monthly" class="input" value="{{ tier.stripe_price_id_monthly or '' }}" placeholder="price_...">
        </div>
        <div>
          <label class="label">Stripe Price ID (yearly)</label>
          <input type="text" name="stripe_price_id_yearly" class="input" value="{{ tier.stripe_price_id_yearly or '' }}" placeholder="price_...">
        </div>
        <div>
          <label class="label">Max Links / Hour <span class="text-muted">(0=∞)</span></label>
          <input type="number" name="max_links_per_hour" class="input" value="{{ tier.max_links_per_hour }}" min="0">
        </div>
        <div>
          <label class="label">Max Total Links <span class="text-muted">(0=∞)</span></label>
          <input type="number" name="max_links_total" class="input" value="{{ tier.max_links_total }}" min="0">
        </div>
        <div>
          <label class="label">Max Total Images <span class="text-muted">(0=∞)</span></label>
          <input type="number" name="max_images_total" class="input" value="{{ tier.max_images_total }}" min="0">
        </div>
        <div>
          <label class="label">Max Total Text Pastes <span class="text-muted">(0=∞)</span></label>
          <input type="number" name="max_text_total" class="input" value="{{ tier.max_text_total }}" min="0">
        </div>
        <div>
          <label class="label">Max DDNS Entries</label>
          <input type="number" name="max_ddns_entries" class="input" value="{{ tier.max_ddns_entries }}" min="0">
        </div>
        <div>
          <label class="label">Max File Size (MB)</label>
          <input type="number" name="max_file_size_mb" class="input" value="{{ tier.max_file_size_mb }}" min="1">
        </div>
        <div>
          <label class="label">Allow Raw HTML</label>
          <select name="allow_raw_html" class="input">
            <option value="1" {% if tier.allow_raw_html %}selected{% endif %}>Yes</option>
            <option value="0" {% if not tier.allow_raw_html %}selected{% endif %}>No</option>
          </select>
        </div>
        <div>
          <label class="label">Show Ads</label>
          <select name="show_ads" class="input">
            <option value="1" {% if tier.show_ads %}selected{% endif %}>Yes</option>
            <option value="0" {% if not tier.show_ads %}selected{% endif %}>No</option>
          </select>
        </div>
        <div>
          <label class="label">Allow Ad Campaigns</label>
          <select name="allow_ad_campaigns" class="input">
            <option value="1" {% if tier.allow_ad_campaigns %}selected{% endif %}>Yes</option>
            <option value="0" {% if not tier.allow_ad_campaigns %}selected{% endif %}>No</option>
          </select>
        </div>
        <div>
          <label class="label">Apply Watermark</label>
          <select name="allow_watermark" class="input">
            <option value="1" {% if tier.allow_watermark %}selected{% endif %}>Yes</option>
            <option value="0" {% if not tier.allow_watermark %}selected{% endif %}>No</option>
          </select>
        </div>
        <input type="hidden" name="is_enabled" value="{{ '1' if tier.is_enabled else '0' }}">
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Save Changes</button>
    </form>
  </div>
  {% endfor %}

  <div class="card mt-3">
    <h3 style="margin-top:0">Add New Tier</h3>
    <form method="POST" action="/admin/account-tiers">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;margin-bottom:1rem">
        <div>
          <label class="label">Tier Name * <span class="text-muted" style="font-weight:400">(e.g. pro)</span></label>
          <input type="text" name="name" class="input" placeholder="pro" required>
        </div>
        <div>
          <label class="label">Display Label</label>
          <input type="text" name="label" class="input" placeholder="Pro">
        </div>
        <div>
          <label class="label">Price ($/month)</label>
          <input type="number" name="price" class="input" value="9.99" min="0" step="0.01">
        </div>
        <div>
          <label class="label">Max Links / Hour</label>
          <input type="number" name="max_links_per_hour" class="input" value="50" min="0">
        </div>
        <div>
          <label class="label">Max DDNS Entries</label>
          <input type="number" name="max_ddns_entries" class="input" value="10" min="0">
        </div>
        <div>
          <label class="label">Max File Size (MB)</label>
          <input type="number" name="max_file_size_mb" class="input" value="50" min="1">
        </div>
        <div>
          <label class="label">Allow Ad Campaigns</label>
          <select name="allow_ad_campaigns" class="input">
            <option value="0">No</option>
            <option value="1">Yes</option>
          </select>
        </div>
        <input type="hidden" name="is_enabled" value="1">
      </div>
      <div class="form-group">
        <label class="label">Description</label>
        <textarea name="description" class="input" rows="2" placeholder="What's included in this plan..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Add Tier</button>
    </form>
  </div>
</div>
{% endblock %}
