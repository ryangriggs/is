{% extends "layouts/base.njk" %}
{% block title %}Reports — Admin — {{ siteName }}{% endblock %}
{% block content %}
<div class="container">
  <div class="page-header">
    <div>
      <h1 class="page-title">Reports</h1>
      <p class="page-subtitle">Reported links needing review</p>
    </div>
    <div class="flex gap-1">
      <a href="?status=pending" class="btn btn-sm {% if query.status == 'pending' or not query.status %}btn-primary{% else %}btn-ghost{% endif %}">Pending</a>
      <a href="?status=all" class="btn btn-sm {% if query.status == 'all' %}btn-primary{% else %}btn-ghost{% endif %}">All</a>
      <a href="/admin" class="btn btn-ghost btn-sm">← Admin</a>
    </div>
  </div>

  {% if reports.length == 0 %}
  <div class="card text-center" style="padding:48px;">
    <div style="font-size:3rem;margin-bottom:16px;">✅</div>
    <h3 class="card-title">No reports</h3>
    <p class="card-body">No pending reports to review.</p>
  </div>
  {% else %}
  <div style="display:flex;flex-direction:column;gap:1rem">
    {% for report in reports %}
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap">
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.5rem">
            {% if report.status == 'pending' %}
              <span class="badge badge-warning">Pending</span>
            {% elif report.status == 'actioned' %}
              <span class="badge badge-success">Actioned</span>
            {% else %}
              <span class="badge badge-neutral">Ignored</span>
            {% endif %}
            {% if report.isReenableRequest %}
              <span class="badge badge-info">Re-enable Request</span>
            {% endif %}
            <a href="https://{{ baseDomain }}/{{ report.linkCode }}" target="_blank" class="font-mono text-sm">
              {{ baseDomain }}/{{ report.linkCode }}
            </a>
            <span class="text-muted text-xs">{{ report.createdAt | date }}</span>
          </div>
          <p class="text-sm" style="margin:0 0 .5rem"><strong>Reason:</strong> {{ report.reason or '—' }}</p>
          {% if report.linkDestination %}
            <p class="text-sm text-muted" style="margin:0 0 .5rem;word-break:break-all">{{ report.linkDestination | truncate(80) }}</p>
          {% endif %}
          <div style="display:flex;gap:1.5rem;flex-wrap:wrap">
            {% if report.ownerUsername %}
            <div class="text-sm">
              <strong>User:</strong> {{ report.ownerUsername }}
              {% if report.ownerIsBlocked %}<span class="badge badge-danger" style="font-size:.7rem">Blocked</span>{% endif %}
            </div>
            {% endif %}
            {% if report.linkCreatorIp %}
            <div class="text-sm">
              <strong>Creator IP:</strong> <code>{{ report.linkCreatorIp }}</code>
              {% if report.creatorIpBlocked %}<span class="badge badge-danger" style="font-size:.7rem">Blocked</span>{% endif %}
            </div>
            {% endif %}
            <div class="text-sm text-muted"><strong>Reporter IP:</strong> <code>{{ report.reporterIp }}</code></div>
          </div>
        </div>
        {% if report.status == 'pending' %}
        <div style="display:flex;flex-direction:column;gap:.4rem;align-items:flex-end">
          <div style="display:flex;gap:.4rem;flex-wrap:wrap">
            <form method="POST" action="/admin/reports/{{ report.id }}/ignore" style="display:inline;">
              <button type="submit" class="btn btn-ghost btn-sm">👍 Ignore</button>
            </form>
            {% if report.isReenableRequest %}
              <form method="POST" action="/admin/reports/{{ report.id }}/enable" style="display:inline;">
                <button type="submit" class="btn btn-success btn-sm" data-confirm="Re-enable this link?">✅ Enable</button>
              </form>
            {% else %}
              <form method="POST" action="/admin/reports/{{ report.id }}/disable" style="display:inline;">
                <button type="submit" class="btn btn-danger btn-sm" data-confirm="Disable this link?">🚫 Disable</button>
              </form>
            {% endif %}
          </div>
          {% if report.ownerId %}
          <div style="display:flex;gap:.4rem;flex-wrap:wrap">
            {% if report.ownerIsBlocked %}
              <form method="POST" action="/admin/reports/{{ report.id }}/unblock-user" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm">✅ Unblock User</button>
              </form>
            {% else %}
              <form method="POST" action="/admin/reports/{{ report.id }}/block-user" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" data-confirm="Block this user?">🚫 Block User</button>
              </form>
            {% endif %}
          </div>
          {% endif %}
          {% if report.linkCreatorIp %}
          <div style="display:flex;gap:.4rem">
            {% if report.creatorIpBlocked %}
              <form method="POST" action="/admin/reports/{{ report.id }}/unblock-ip" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm">✅ Unblock IP</button>
              </form>
            {% else %}
              <form method="POST" action="/admin/reports/{{ report.id }}/block-ip" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" data-confirm="Block IP {{ report.linkCreatorIp }}?">🚫 Block IP</button>
              </form>
            {% endif %}
          </div>
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</div>
{% endblock %}
