{% extends "layouts/base.njk" %}
{% block title %}Settings — Admin — {{ siteName }}{% endblock %}
{% block content %}
<div class="container">
  <div class="page-header">
    <div>
      <h1 class="page-title">Site Settings</h1>
      <p class="page-subtitle">Global configuration</p>
    </div>
    <a href="/admin" class="btn btn-ghost btn-sm">← Admin</a>
  </div>

  {# ── Update status bar ── #}
  <div class="card mb-4" id="update" style="max-width:900px;display:flex;align-items:center;flex-wrap:wrap;gap:1rem;justify-content:space-between">
    <div>
      <span style="font-size:.875rem">Current version: <strong>v{{ appVersion }}</strong></span>
      {% if updateInfo.latest %}
        <span style="margin-left:.5rem;font-size:.875rem">— Latest: <strong>v{{ updateInfo.latest }}</strong></span>
        {% if updateInfo.updateAvailable %}
          <span class="badge badge-warning" style="margin-left:.35rem">Update available</span>
        {% else %}
          <span class="badge badge-success" style="margin-left:.35rem">Up to date</span>
        {% endif %}
      {% else %}
        <span class="text-muted text-sm" style="margin-left:.5rem">— Not checked yet</span>
      {% endif %}
      {% if updateInfo.checkedAt %}
        <div class="text-muted text-xs" style="margin-top:.2rem">Last checked: {{ updateInfo.checkedAt | date }}</div>
      {% endif %}
    </div>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
      {% if updateInfo.updateAvailable %}
      <form method="POST" action="/admin/update/apply" style="margin:0" id="update-apply-form">
        <button class="btn btn-primary btn-sm" id="update-apply-btn">⬆ Update Now</button>
      </form>
      {% endif %}
      <form method="POST" action="/admin/update/check" style="margin:0">
        <button class="btn btn-ghost btn-sm">🔄 Check Now</button>
      </form>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; max-width:900px;">
    <div class="card">
      <h2 class="card-title mb-3">Site Settings</h2>
      <form method="POST" action="/admin/settings">
        <div class="form-group">
          <label class="label">Site Name</label>
          <input type="text" name="site_name" class="input" value="{{ settings.site_name }}">
        </div>
        <div class="form-group">
          <label class="label">Site Tagline</label>
          <input type="text" name="site_tagline" class="input" value="{{ settings.site_tagline }}">
        </div>
        <div class="form-group">
          <label class="label">Registration</label>
          <select name="registration_open" class="select">
            <option value="true" {% if settings.registration_open == 'true' %}selected{% endif %}>Open</option>
            <option value="false" {% if settings.registration_open == 'false' %}selected{% endif %}>Closed</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Save Settings</button>
      </form>
    </div>

    <div>
      <div class="card mb-3">
        <h2 class="card-title mb-3">Watermark</h2>
        {% if settings.watermark_image_path %}
        <div style="margin-bottom:.75rem;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
          <img src="/{{ settings.watermark_image_path }}" alt="Watermark" style="max-height:40px;background:repeating-conic-gradient(#ccc 0% 25%, transparent 0% 50%) 0 0/10px 10px;border-radius:4px;padding:4px">
          <form method="POST" action="/admin/settings/watermark/remove" style="margin:0">
            <button class="btn btn-ghost btn-sm">Remove</button>
          </form>
        </div>
        {% else %}
        <p class="text-sm text-muted mb-2">No watermark set.</p>
        {% endif %}
        <form method="POST" action="/admin/settings/watermark" enctype="multipart/form-data">
          <div class="form-group">
            <label class="label">Watermark PNG</label>
            <input type="file" name="logo" class="input" accept="image/png">
            <p class="text-xs text-muted mt-1">Transparent PNG recommended.</p>
          </div>
          <button type="submit" class="btn btn-primary btn-sm btn-block">Upload Watermark</button>
        </form>
        <form method="POST" action="/admin/settings" style="margin-top:1rem">
          <div class="form-group">
            <label class="label">Position</label>
            <select name="watermark_position" class="select">
              {% for pos in ['bottom-right','bottom-left','bottom-center','top-right','top-left','top-center','center'] %}
              <option value="{{ pos }}" {% if settings.watermark_position == pos %}selected{% endif %}>{{ pos }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="form-group">
            <label class="label">Size (% of image height)</label>
            <input type="number" name="watermark_size_pct" class="input" value="{{ settings.watermark_size_pct or '15' }}" min="1" max="100">
          </div>
          <button type="submit" class="btn btn-secondary btn-sm btn-block">Save Watermark Settings</button>
        </form>
      </div>

      <div class="card mb-3">
        <h2 class="card-title mb-3">Ads</h2>
        <form method="POST" action="/admin/settings">
          <div class="form-group">
            <label class="label">URL interstitial countdown (seconds)</label>
            <input type="number" name="ad_interstitial_seconds" class="input" value="{{ settings.ad_interstitial_seconds or '5' }}" min="1" max="60">
          </div>
          <div class="form-group">
            <label class="label">Ad image height (px)</label>
            <input type="number" name="ad_image_height" class="input" value="{{ settings.ad_image_height or '90' }}" min="40" max="400">
            <p class="text-xs text-muted mt-1">Images are scaled to this height and centered. Width fills the container.</p>
          </div>
          <button type="submit" class="btn btn-primary btn-sm btn-block">Save</button>
        </form>
      </div>

      <div class="card mb-3">
        <h2 class="card-title mb-3">Stripe Payments</h2>
        <form method="POST" action="/admin/settings">
          <div class="form-group">
            <label class="label">Payments</label>
            <select name="stripe_enabled" class="select">
              <option value="false" {% if settings.stripe_enabled != 'true' %}selected{% endif %}>Disabled</option>
              <option value="true" {% if settings.stripe_enabled == 'true' %}selected{% endif %}>Enabled</option>
            </select>
          </div>
          <div class="form-group">
            <label class="label">Secret Key <span class="text-muted" style="font-weight:400">(sk_live_... or sk_test_...)</span></label>
            <input type="password" name="stripe_secret_key" class="input"
              placeholder="{{ '(set — leave blank to keep)' if settings.stripe_secret_key else 'sk_live_...' }}"
              autocomplete="off">
          </div>
          <div class="form-group">
            <label class="label">Webhook Signing Secret <span class="text-muted" style="font-weight:400">(whsec_...)</span></label>
            <input type="password" name="stripe_webhook_secret" class="input"
              placeholder="{{ '(set — leave blank to keep)' if settings.stripe_webhook_secret else 'whsec_...' }}"
              autocomplete="off">
            <p class="text-xs text-muted mt-1">
              Webhook endpoint: <code>https://{{ baseDomain }}/stripe/webhook</code><br>
              Events: <code>checkout.session.completed</code>, <code>customer.subscription.updated</code>,
              <code>customer.subscription.deleted</code>, <code>invoice.payment_failed</code>
            </p>
          </div>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap">
            <button type="submit" class="btn btn-primary btn-sm">Save</button>
            {% if settings.stripe_secret_key %}
            <a href="https://dashboard.stripe.com" target="_blank" rel="noopener" class="btn btn-ghost btn-sm">Stripe Dashboard ↗</a>
            {% endif %}
          </div>
        </form>
      </div>

      <div class="card mb-3">
        <h2 class="card-title mb-3">Update Settings</h2>
        <form method="POST" action="/admin/settings">
          <div class="form-group">
            <label class="label">GitHub Repo URL</label>
            <input type="url" name="github_repo_url" class="input"
              value="{{ settings.github_repo_url or 'https://github.com/ryangriggs/is' }}"
              placeholder="https://github.com/owner/repo">
            <p class="text-xs text-muted mt-1">Used to fetch <code>version.json</code> for update checks.</p>
          </div>
          <div class="form-group">
            <label class="label">Check interval (hours)</label>
            <input type="number" name="update_check_hours" class="input"
              value="{{ settings.update_check_hours or '24' }}" min="1" max="720">
          </div>
          <button type="submit" class="btn btn-primary btn-block">Save</button>
        </form>
      </div>

      <div class="card mb-3">
        <h2 class="card-title mb-3">Site Logo</h2>
        {% if siteLogo %}
        <div style="margin-bottom:.75rem;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
          <img src="{{ siteLogo }}" alt="Current logo" style="max-height:48px;max-width:160px;object-fit:contain;border-radius:4px;background:var(--bg-card);padding:4px">
          <form method="POST" action="/admin/settings/logo/remove" style="margin:0">
            <button class="btn btn-ghost btn-sm">Remove (text only)</button>
          </form>
        </div>
        {% else %}
        <p class="text-sm text-muted mb-2">No logo set — site name shown as text.</p>
        {% endif %}
        <form method="POST" action="/admin/settings/logo" enctype="multipart/form-data">
          <div class="form-group">
            <label class="label">Upload Logo</label>
            <input type="file" name="logo" class="input" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml">
            <p class="text-xs text-muted mt-1">PNG, JPG, GIF, WebP, or SVG. Recommended: transparent PNG, height ≤ 64px.</p>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Upload Logo</button>
        </form>
      </div>

      <div class="card">
        <h2 class="card-title mb-3">Theme</h2>
        <form method="POST" action="/admin/settings">
          <div class="form-group">
            <label class="label">Active Theme</label>
            <select name="active_theme" class="select" id="theme-select">
              {% for t in availableThemes %}
              <option value="{{ t }}" {% if t == settings.active_theme or (not settings.active_theme and t == 'default') %}selected{% endif %}>{{ t }}</option>
              {% endfor %}
            </select>
            <p class="text-xs text-muted mt-1">Takes effect on next server restart.</p>
          </div>
          <button type="submit" class="btn btn-secondary btn-block">Save Theme</button>
        </form>
      </div>
    </div>
  </div>
</div>

{% if updateInfo.updateAvailable %}
{# Update overlay — shown after clicking Update Now #}
<div id="update-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:9999;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem">
  <style>
    @keyframes upd-spin { to { transform: rotate(360deg); } }
    #update-spinner { width:56px;height:56px;border-radius:50%;border:5px solid rgba(255,255,255,.2);border-top-color:#fff;animation:upd-spin .8s linear infinite; }
    #update-overlay-msg { color:#fff;font-size:1.1rem;font-weight:500;text-align:center; }
    #update-overlay-sub { color:rgba(255,255,255,.6);font-size:.875rem;text-align:center; }
  </style>
  <div id="update-spinner"></div>
  <div id="update-overlay-msg">Applying update…</div>
  <div id="update-overlay-sub">Please wait while the app restarts.</div>
</div>
<script>
(function() {
  var form = document.getElementById('update-apply-form')
  var btn  = document.getElementById('update-apply-btn')
  var overlay = document.getElementById('update-overlay')
  var msg = document.getElementById('update-overlay-msg')
  var sub = document.getElementById('update-overlay-sub')
  if (!form || !overlay) return

  form.addEventListener('submit', function(e) {
    e.preventDefault()
    if (!confirm('Apply update and restart the app?')) return

    overlay.style.display = 'flex'
    btn.disabled = true

    // Fire the POST — server will exit shortly after responding
    fetch(form.action, { method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' } })
      .catch(function() {})

    // Wait for restart to begin, then poll /ping until the server responds
    setTimeout(function() {
      msg.textContent = 'Waiting for server to restart…'
      var elapsed = 0
      var interval = setInterval(function() {
        elapsed += 1500
        if (elapsed >= 120000) {
          clearInterval(interval)
          msg.textContent = 'Taking longer than expected…'
          sub.textContent = 'Refresh manually when ready.'
          return
        }
        fetch('/ping', { cache: 'no-store', credentials: 'same-origin' })
          .then(function(r) {
            if (r.ok) {
              clearInterval(interval)
              msg.textContent = 'Update complete! Reloading…'
              sub.textContent = ''
              setTimeout(function() { location.reload() }, 800)
            }
          })
          .catch(function() {}) // still down — keep polling
      }, 1500)
    }, 3000)
  })
})()
</script>
{% endif %}
{% endblock %}
