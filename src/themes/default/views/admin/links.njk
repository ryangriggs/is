{% extends "layouts/base.njk" %}
{% block title %}Links — Admin — {{ siteName }}{% endblock %}
{% block content %}
<div class="container">
  <div class="page-header">
    <div>
      <h1 class="page-title">Links</h1>
      <p class="page-subtitle">{{ pagination.total }} total links</p>
    </div>
    <div class="flex gap-1">
      <a href="/admin" class="btn btn-ghost btn-sm">← Admin</a>
    </div>
  </div>

  <form method="GET" action="/admin/links" class="card mb-3" style="padding:16px;">
    <div class="input-group">
      <input type="text" name="q" class="input" placeholder="Search by code or URL..." value="{{ query.q }}">
      <select name="sort" class="select" style="width:160px;">
        <option value="created_at" {% if query.sort == 'created_at' %}selected{% endif %}>Date Created</option>
        <option value="code" {% if query.sort == 'code' %}selected{% endif %}>Code</option>
      </select>
      <select name="dir" class="select" style="width:110px;">
        <option value="desc" {% if query.dir == 'desc' %}selected{% endif %}>Newest</option>
        <option value="asc" {% if query.dir == 'asc' %}selected{% endif %}>Oldest</option>
      </select>
      <button type="submit" class="btn btn-secondary">Filter</button>
      <a href="/admin/links" class="btn btn-ghost">Reset</a>
    </div>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Code</th>
          <th>Destination</th>
          <th>Owner</th>
          <th>Type</th>
          <th>Created</th>
          <th>Visits</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% if links.length == 0 %}
        <tr><td colspan="8" class="text-center text-muted" style="padding:32px;">No links found.</td></tr>
        {% endif %}
        {% for link in links %}
        <tr>
          <td class="td-code">
            <a href="https://{{ baseDomain }}/{{ link.code }}" target="_blank" rel="noopener">{{ link.code }}</a>
          </td>
          <td class="td-url" title="{{ link.destination }}">{{ link.destination }}</td>
          <td class="text-muted text-sm">{{ link.username or '—' }}</td>
          <td><span class="badge badge-neutral">{{ link.type }}</span></td>
          <td class="text-muted text-sm">{{ link.createdAt | date }}</td>
          <td>{{ link.visitCount or 0 }}</td>
          <td>
            {% if link.isActive %}
              <span class="badge badge-success">Active</span>
            {% else %}
              <span class="badge badge-danger">Inactive</span>
            {% endif %}
          </td>
          <td class="td-actions">
            <form method="POST" action="/admin/links/{{ link.id }}/toggle" style="display:inline;">
              <button type="submit" class="btn btn-ghost btn-sm" title="{{ 'Deactivate' if link.isActive else 'Activate' }}">
                {{ '⏸' if link.isActive else '▶️' }}
              </button>
            </form>
            <form method="POST" action="/admin/links/{{ link.id }}/delete" style="display:inline;">
              <button type="submit" class="btn btn-danger btn-sm"
                data-confirm="Delete this link permanently?" title="Delete">🗑</button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if pagination.totalPages > 1 %}
  <div class="pagination">
    {% if pagination.page > 1 %}
      <a href="?page={{ pagination.page - 1 }}&q={{ query.q }}&sort={{ query.sort }}&dir={{ query.dir }}">‹ Prev</a>
    {% else %}
      <span class="disabled">‹ Prev</span>
    {% endif %}
    <span>Page {{ pagination.page }} of {{ pagination.totalPages }}</span>
    {% if pagination.page < pagination.totalPages %}
      <a href="?page={{ pagination.page + 1 }}&q={{ query.q }}&sort={{ query.sort }}&dir={{ query.dir }}">Next ›</a>
    {% else %}
      <span class="disabled">Next ›</span>
    {% endif %}
  </div>
  {% endif %}
</div>
{% endblock %}
