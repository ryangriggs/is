{% extends "layouts/base.njk" %}
{% block title %}{{ link.title or 'Bookmarks' }} — {{ siteName }}{% endblock %}
{% block content %}
<section class="section">
  <div class="container" style="max-width:720px">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem">
      <div>
        <h1 style="margin:0;font-size:1.25rem">{{ link.title or 'Untitled Collection' }}</h1>
        <p class="text-muted text-sm" style="margin:.25rem 0 0">
          Share: <a href="{{ shortUrl }}">{{ shortUrl }}</a>
          <button class="btn btn-ghost btn-sm" data-copy="{{ shortUrl }}" style="padding:2px 7px;font-size:.75rem;margin-left:4px">📋</button>
        </p>
      </div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center">

        {# Visibility toggle — orange=public, blue=private, labels both sides #}
        <form method="POST" action="/b/{{ link.code }}/visibility" style="margin:0;display:flex;align-items:center;gap:.5rem">
          <span class="text-sm">Private</span>
          <label class="slide-toggle slide-toggle-vis" title="Toggle public/private" style="cursor:pointer">
            <input type="checkbox" onchange="this.form.submit()" {% if not link.is_private %}checked{% endif %}>
            <span class="slide-knob"></span>
          </label>
          <span class="text-sm">Public</span>
        </form>

        {# Password button + popup #}
        <div class="pw-popup-wrap">
          <button type="button" id="pw-btn" class="btn btn-ghost btn-sm"
                  title="{{ 'Password protected — click to change' if link.password_hash else 'Set a password' }}">
            🔑{% if link.password_hash %}<span style="font-size:.6rem;vertical-align:top;color:var(--color-primary)">●</span>{% endif %}
          </button>
          <div class="pw-popup" id="pw-popup">
            <p style="font-size:.8rem;color:var(--color-text-muted);margin:0 0 .75rem">
              {% if link.password_hash %}🔒 Password is currently set.{% else %}🔓 No password set.{% endif %}
            </p>
            <form method="POST" action="/b/{{ link.code }}/password">
              <input type="password" name="password" class="input" placeholder="New password" style="margin-bottom:.5rem" autocomplete="new-password">
              <button type="submit" class="btn btn-primary btn-sm" style="width:100%">Set Password</button>
            </form>
            {% if link.password_hash %}
            <form method="POST" action="/b/{{ link.code }}/password" style="margin-top:.4rem">
              <input type="hidden" name="remove" value="1">
              <button type="submit" class="btn btn-danger btn-sm" style="width:100%">Remove Password</button>
            </form>
            {% endif %}
          </div>
        </div>

        <form method="POST" action="/b/{{ link.code }}/delete" style="margin:0">
          <button class="btn btn-danger btn-sm" data-confirm="Delete this collection and all bookmarks?">Delete</button>
        </form>
        <a href="/b" class="btn btn-secondary btn-sm">← Collections</a>
      </div>
    </div>

    <div class="card mb-4">
      <h2 style="font-size:1rem;margin:0 0 1rem">Add Bookmark</h2>
      <form method="POST" action="/b/{{ link.code }}/add">
        <div class="form-group">
          <input type="url" name="url" class="input" placeholder="https://example.com" required>
        </div>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap">
          <input type="text" name="title" class="input" placeholder="Title (optional)" style="flex:1;min-width:140px">
          <input type="text" name="folder" class="input" placeholder="Folder (optional)" style="flex:1;min-width:140px">
          <button type="submit" class="btn btn-primary">Add</button>
        </div>
      </form>
    </div>

    {% if items.length %}
    {% set currentFolder = '' %}
    {% for item in items %}
      {% if item.folder and item.folder != currentFolder %}
        {% set currentFolder = item.folder %}
        <h3 style="font-size:.875rem;text-transform:uppercase;letter-spacing:.05em;color:var(--color-text-muted);margin:1rem 0 .5rem">{{ item.folder }}</h3>
      {% endif %}
      <div class="card" style="margin-bottom:.5rem;padding:.75rem 1rem">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem">
          <div style="min-width:0;flex:1">
            <a href="{{ item.url }}" target="_blank" rel="noopener" style="font-weight:500;word-break:break-word">{{ item.title or item.url }}</a>
            <div style="margin-top:.35rem;display:flex;flex-wrap:wrap;align-items:center;gap:.4rem">
              {# Actual URL as a copy button #}
              <a href="{{ item.url }}" target="_blank" rel="noopener"
                 class="badge badge-neutral" style="font-size:.72rem;text-decoration:none;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                 title="{{ item.url }}">{{ item.url | truncate(50) }}</a>
              <button class="btn btn-ghost btn-sm" style="padding:1px 6px;font-size:.72rem"
                      data-copy="{{ item.url }}" title="Copy URL">📋</button>
              {# Shortlink (only if one was created at add time) #}
              {% if item.shortlink_code %}
              <span style="color:var(--color-text-dim);font-size:.7rem">·</span>
              <a href="https://{{ baseDomain }}/{{ item.shortlink_code }}" target="_blank" rel="noopener"
                 class="badge badge-info" style="font-family:monospace;font-size:.72rem;text-decoration:none">
                {{ baseDomain }}/{{ item.shortlink_code }}
              </a>
              <button class="btn btn-ghost btn-sm" style="padding:1px 6px;font-size:.72rem"
                      data-copy="https://{{ baseDomain }}/{{ item.shortlink_code }}" title="Copy shortlink">📋</button>
              {% endif %}
            </div>
          </div>
          <form method="POST" action="/b/{{ link.code }}/delete/{{ item.id }}" style="margin:0;flex-shrink:0">
            <button class="btn btn-ghost btn-sm" data-confirm="Remove this bookmark?">✕</button>
          </form>
        </div>
      </div>
    {% endfor %}
    {% else %}
    <div class="card text-center text-muted">No bookmarks yet. Add one above.</div>
    {% endif %}
  </div>
</section>

<script>
  var pwBtn = document.getElementById('pw-btn')
  var pwPopup = document.getElementById('pw-popup')
  if (pwBtn && pwPopup) {
    pwBtn.addEventListener('click', function(e) {
      e.stopPropagation()
      pwPopup.classList.toggle('open')
    })
    document.addEventListener('click', function() { pwPopup.classList.remove('open') })
    pwPopup.addEventListener('click', function(e) { e.stopPropagation() })
  }
</script>
{% endblock %}
