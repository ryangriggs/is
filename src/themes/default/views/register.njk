{% extends "layouts/base.njk" %}
{% block title %}Create Account — {{ siteName }}{% endblock %}
{% block scripts %}
{% if captchaEnabled %}
<script type="module" src="https://cdn.jsdelivr.net/npm/altcha/dist/altcha.min.js" async defer></script>
{% endif %}
{% endblock %}
{% block content %}
{% include "partials/ad-banner.njk" %}
<div class="auth-wrap">
  <div class="auth-card">
    <h1 class="auth-title">Create account</h1>
    <p class="auth-subtitle">Free forever. No credit card required.</p>

    {% if error %}
    <div class="alert alert-error mb-3">{{ error }}</div>
    {% endif %}

    {% if registrationClosed %}
    <div class="alert alert-warning">Registration is currently closed. Please check back later.</div>
    {% else %}
    <a href="/auth/google" class="btn btn-google btn-block btn-lg">
      <svg width="18" height="18" viewBox="0 0 18 18" style="vertical-align:middle;margin-right:.5rem" aria-hidden="true"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z"/></svg>
      Continue with Google
    </a>

    <div class="auth-divider"><span>or</span></div>

    <form method="POST" action="/register">
      <div class="form-group">
        <label class="label" for="email">Email Address</label>
        <input id="email" type="email" name="email" class="input"
          value="{{ prefill.email }}" required autocomplete="email" autofocus>
      </div>
      <div class="form-group">
        <label class="label" for="display_name">Display Name <span class="text-xs text-muted">(optional)</span></label>
        <input id="display_name" type="text" name="display_name" class="input"
          value="{{ prefill.display_name }}" autocomplete="name" placeholder="How you'd like to be called">
      </div>
      <div class="form-group">
        <label class="label" for="password">Password</label>
        <input id="password" type="password" name="password" class="input"
          required minlength="8" autocomplete="new-password">
        <p class="text-xs text-muted mt-1">At least 8 characters.</p>
      </div>
      <div class="form-group">
        <label class="label" for="password2">Confirm Password</label>
        <input id="password2" type="password" name="password2" class="input"
          required autocomplete="new-password">
      </div>
      {% if captchaEnabled %}
      <div class="form-group">
        <altcha-widget challengeurl="/altcha-challenge" style="color-scheme:inherit"></altcha-widget>
      </div>
      {% endif %}
      <button type="submit" class="btn btn-primary btn-block btn-lg">Create Account</button>
    </form>
    {% endif %}

    <p class="text-center text-sm text-muted mt-3">
      Already have an account? <a href="/login">Log in</a>
    </p>
  </div>
</div>
{% endblock %}
