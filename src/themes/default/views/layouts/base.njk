<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ siteName }}{% endblock %}</title>
  <meta name="description" content="{{ siteTagline }}">
  <link rel="stylesheet" href="/static/theme.css">
  {% if siteLogo %}<link rel="icon" href="{{ siteLogo }}">{% endif %}
  {% block head %}{% endblock %}
</head>
<body class="{% block bodyClass %}{% endblock %}">

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        {% if siteLogo %}<img src="{{ siteLogo }}" alt="{{ siteName }}">{% endif %}
        <span class="nav-logo-text">{{ siteName }}</span>
      </a>
      <ul class="nav-links">
        {% if user %}
          <li><a href="/dashboard" class="{% if currentPath == '/dashboard' %}active{% endif %}">Dashboard</a></li>
          <li><a href="/tokens" class="{% if currentPath == '/tokens' %}active{% endif %}">API</a></li>
          {% if user.role == 'admin' %}
            <li><a href="/admin" class="{% if '/admin' in currentPath %}active{% endif %}">Admin</a></li>
          {% endif %}
          <li>
            <form method="POST" action="/logout" style="margin:0">
              <button type="submit" class="btn btn-ghost btn-sm">Logout</button>
            </form>
          </li>
        {% else %}
          <li class="nav-link-hide"><a href="/login">Login</a></li>
          <li><a href="/register" class="btn btn-primary btn-sm">Sign up</a></li>
        {% endif %}
      </ul>
    </div>
  </nav>

  <main class="page-content">
    {% if flash and flash.type != 'key' %}
      <div class="container mt-2">
        <div class="alert alert-{{ flash.type }} flash-auto">{{ flash.message }}</div>
      </div>
    {% endif %}

    {% block content %}{% endblock %}
  </main>

  {% if flash and flash.type == 'key' %}
  <div class="key-modal-backdrop" id="key-modal">
    <div class="key-modal">
      <div class="key-modal-icon">🔑</div>
      <h2 class="key-modal-title">{{ flash.label }}</h2>
      <p class="key-modal-sub">{{ flash.sublabel }}</p>
      <div class="key-modal-value">
        <code id="key-value">{{ flash.key }}</code>
      </div>
      <div class="key-modal-actions">
        <button class="btn btn-primary" data-copy-target="key-value" id="copy-key-btn">📋 Copy Key</button>
        <button class="btn btn-ghost" id="dismiss-key-modal">Got it, I've saved it</button>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('dismiss-key-modal').addEventListener('click', function() {
      document.getElementById('key-modal').remove()
    })
    document.getElementById('key-modal').addEventListener('click', function(e) {
      if (e.target === this) this.remove()
    })
  </script>
  {% endif %}

  <footer class="footer">
    <div class="container">
      <p>
        &copy; {{ siteName }} &mdash;
        <a href="https://github.com/your-repo/is.am" target="_blank" rel="noopener">Open Source</a>
        &nbsp;&bull;&nbsp;
        <a href="/report">Report a link</a>
      </p>
    </div>
  </footer>

  <script src="https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js" defer></script>
  <script src="/static/app.js" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
