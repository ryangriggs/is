<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ siteName }}{% endblock %}</title>
  <meta name="description" content="{{ siteTagline }}">
  <link rel="stylesheet" href="/static/theme.css">
  {% if siteLogo %}<link rel="icon" href="{{ siteLogo }}">{% endif %}
  {% block head %}{% endblock %}
  <style>
    /* Day/night mode — light overrides */
    [data-theme="light"] {
      --bg-base: #f0f4ff;
      --bg-surface: #ffffff;
      --bg-card: rgba(0,0,0,0.04);
      --bg-card-hover: rgba(0,0,0,0.07);
      --bg-input: rgba(0,0,0,0.06);
      --color-text: #1e293b;
      --color-text-muted: #475569;
      --color-text-dim: #94a3b8;
      --color-border: rgba(0,0,0,0.12);
      --color-border-focus: rgba(99,102,241,0.5);
      --gradient-hero: linear-gradient(135deg, #eef2ff 0%, #f5f3ff 50%, #eff6ff 100%);
      --shadow-card: 0 4px 24px rgba(0,0,0,0.08), 0 0 0 1px var(--color-border);
    }
    [data-theme="light"] .nav {
      background: rgba(255, 255, 255, 0.909);
    }
    [data-theme="light"] .nav-links a { color: var(--color-text-muted); }
    [data-theme="light"] .nav-links a:hover { color: var(--color-text); }

    /* Avatar & dropdown */
    .nav-avatar-wrap { position: relative; }
    .nav-avatar-btn {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--gradient-btn); color: #fff; border: none;
      cursor: pointer; font-weight: 700; font-size: .8rem;
      display: flex; align-items: center; justify-content: center;
      transition: opacity 150ms; line-height: 1;
    }
    .nav-avatar-btn:hover { opacity: .85; }
    .nav-avatar-drop {
      position: absolute; right: 0; top: calc(100% + 8px);
      background: var(--bg-surface); border: 1px solid var(--color-border);
      border-radius: var(--radius-lg); min-width: 190px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3); overflow: hidden;
      display: none; z-index: 300;
    }
    .nav-avatar-drop.open { display: block; }
    .nav-drop-header {
      padding: 10px 14px; font-size: .78rem; color: var(--color-text-muted);
      border-bottom: 1px solid var(--color-border); word-break: break-all;
    }
    .nav-drop-header strong { display: block; color: var(--color-text); font-size: .85rem; }
    .nav-avatar-drop a, .nav-avatar-drop button {
      display: block; width: 100%; padding: 9px 14px;
      font-size: .875rem; color: var(--color-text); background: none;
      border: none; text-align: left; cursor: pointer;
      text-decoration: none; transition: background 150ms; border-radius: 0;
    }
    .nav-avatar-drop a:hover, .nav-avatar-drop button:hover {
      background: var(--bg-card-hover); color: var(--color-text);
    }
    .nav-avatar-drop .drop-divider { height: 1px; background: var(--color-border); margin: 4px 0; }

    /* New button dropdown in nav */
    .nav-new-wrap { position: relative; }
    .nav-new-drop {
      position: absolute; left: 0; top: calc(100% + 8px);
      background: var(--bg-surface); border: 1px solid var(--color-border);
      border-radius: var(--radius-lg); min-width: 200px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3); overflow: hidden;
      display: none; z-index: 300;
    }
    .nav-new-drop.open { display: block; }
    .nav-new-drop a {
      display: flex; align-items: center; gap: 8px;
      padding: 9px 14px; font-size: .875rem; color: var(--color-text);
      text-decoration: none; transition: background 150ms; border-radius: 0;
    }
    .nav-new-drop a:hover { background: var(--bg-card-hover); color: var(--color-text); }

    /* Unread badge pulse */
    @keyframes pulse-badge {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: .75; transform: scale(1.2); }
    }
    .badge-pulse { animation: pulse-badge 1.5s ease-in-out infinite; display: inline-block; }

    /* Slide toggle for private/public */
    .slide-toggle-wrap { display: inline-flex; align-items: center; gap: .5rem; }
    .slide-toggle { position: relative; display: inline-block; width: 48px; height: 26px; }
    .slide-toggle input { opacity: 0; width: 0; height: 0; }
    .slide-knob {
      position: absolute; inset: 0; cursor: pointer;
      background: var(--color-danger); border-radius: 26px;
      transition: background .3s;
    }
    .slide-knob::before {
      content: ''; position: absolute;
      height: 20px; width: 20px; left: 3px; bottom: 3px;
      background: #fff; border-radius: 50%; transition: transform .3s;
    }
    .slide-toggle input:checked + .slide-knob { background: var(--color-success); }
    .slide-toggle input:checked + .slide-knob::before { transform: translateX(22px); }
    /* Visibility toggle variant: blue = private (unchecked), orange = public (checked) */
    .slide-toggle-vis .slide-knob { background: #3b82f6 !important; }
    .slide-toggle-vis input:checked + .slide-knob { background: #f59e0b !important; }

    /* Key modal */
    .key-modal-backdrop {
      position: fixed; inset: 0; background: rgba(0,0,0,.7);
      display: flex; align-items: center; justify-content: center;
      z-index: 1000; padding: 1rem;
    }
    .key-modal {
      background: var(--bg-surface); border: 1px solid var(--color-border);
      border-radius: var(--radius-xl); padding: 2rem; max-width: 480px; width: 100%;
      text-align: center; box-shadow: 0 24px 48px rgba(0,0,0,.5);
    }
    .key-modal-icon { font-size: 2.5rem; margin-bottom: .75rem; }
    .key-modal-title { font-size: 1.25rem; font-weight: 700; margin-bottom: .25rem; }
    .key-modal-sub { color: var(--color-text-muted); font-size: .875rem; margin-bottom: 1.25rem; }
    .key-modal-value {
      background: var(--bg-card); border: 1px solid var(--color-border);
      border-radius: var(--radius); padding: .75rem 1rem; margin-bottom: 1.25rem;
      word-break: break-all; font-size: .85rem;
    }
    .key-modal-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
  </style>
  <script>
    ;(function(){
      var t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
      document.documentElement.setAttribute('data-theme', t)
    })()
  </script>
</head>
<body class="{% block bodyClass %}{% endblock %}">

  <nav class="nav" style="position:sticky;top:0;z-index:200">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        {% if siteLogo %}
          <img src="{{ siteLogo }}" alt="{{ siteName }}" style="max-height:32px;max-width:140px;object-fit:contain;display:block">
        {% else %}
          <span class="nav-logo-text">{{ siteName }}</span>
        {% endif %}
      </a>

      {# ── Center group: + New button + desktop nav links ── #}
      <div style="display:flex;align-items:center;gap:.5rem">
        <div class="nav-new-wrap">
          <button class="btn btn-primary" id="nav-new-btn" style="gap:4px;font-size:.95rem;padding:.4rem 1rem">+ New ▾</button>
          <div class="nav-new-drop" id="nav-new-drop">
            <a href="/">🔗 URL Shortlink</a>
            <a href="/t">📝 Text Paste</a>
            <a href="/h">🌐 HTML Paste</a>
            <a href="/i">🖼️ Image Upload</a>
            <a href="/q">⬛ QR Code</a>
            {% if user %}
            <a href="/b">🔖 Bookmark Collection</a>
            <a href="/d">🌍 Dynamic DNS</a>
            {% endif %}
          </div>
        </div>

        {# Desktop nav links (hidden on mobile via CSS) #}
        <ul class="nav-links">
          {% if user %}
            <li><a href="/dashboard" class="{% if currentPath == '/dashboard' %}active{% endif %}">Dashboard</a></li>
          {% endif %}
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/contact">Contact</a></li>
          <li>
            <button id="theme-toggle" class="btn btn-ghost btn-sm" title="Toggle theme" style="padding:6px 8px;font-size:1rem">🌙</button>
          </li>
        </ul>
      </div>

      {# ── Always-visible right section: hamburger, avatar ── #}
      <div class="nav-actions">
        <button class="nav-hamburger" id="hamburger-btn" title="Menu">☰</button>
        {% if user %}
          <div class="nav-avatar-wrap">
            <button class="nav-avatar-btn" id="avatar-btn" title="Account">
              {% if user.displayName %}{{ user.displayName[0] | upper }}{% elif user.email %}{{ user.email[0] | upper }}{% else %}?{% endif %}
            </button>
            <div class="nav-avatar-drop" id="avatar-drop">
              <div class="nav-drop-header">
                {% if user.displayName %}<strong>{{ user.displayName }}</strong>{% endif %}
                {{ user.email or user.username }}
              </div>
              <a href="/dashboard">Dashboard</a>
              <a href="/profile">Profile</a>
              <a href="/b">Bookmarks</a>
              <a href="/pricing">Subscription</a>
              <a href="/tokens">API Tokens</a>
              <a href="/ads">Ad Campaigns</a>
              {% if user.role == 'admin' %}
              <a href="/admin">Admin{% if unreadMessages > 0 %} <span class="badge badge-danger badge-pulse" style="font-size:.65rem">{{ unreadMessages }}</span>{% endif %}</a>
              {% endif %}
              <div class="drop-divider"></div>
              <form method="POST" action="/logout" style="margin:0">
                <button type="submit">Log out</button>
              </form>
            </div>
          </div>
        {% else %}
          <a href="/login" class="btn btn-ghost btn-sm">Login</a>
          <a href="/register" class="btn btn-primary btn-sm">Sign up</a>
        {% endif %}
      </div>
    </div>

    {# ── Mobile slide-down menu (nav links only — no account) ── #}
    <div class="nav-mobile-menu" id="nav-mobile-menu">
      {% if user %}
        <a href="/dashboard">Dashboard</a>
        <a href="/pricing">Pricing</a>
        <a href="/contact">Contact</a>
      {% else %}
        <a href="/pricing">Pricing</a>
        <a href="/login">Login</a>
        <a href="/register">Sign up</a>
        <a href="/contact">Contact</a>
      {% endif %}
      <div class="mob-divider"></div>
      <button id="theme-toggle-mob" class="mob-link" title="Toggle theme">🌙 Toggle Day / Night</button>
    </div>
  </nav>

  {% if showUpdateBanner %}
  <div id="update-banner" style="background:#f59e0b;color:#000;padding:.45rem 1rem;text-align:center;font-size:.85rem;display:flex;align-items:center;justify-content:center;gap:.75rem;flex-wrap:wrap">
    <span>🆕 Update available: <strong>v{{ updateLatest }}</strong></span>
    <a href="/admin/settings#update" style="background:#000;color:#fff;padding:2px 10px;border-radius:4px;font-size:.8rem;text-decoration:none;font-weight:600">Update Now</a>
    <button onclick="dismissUpdate('{{ updateLatest }}')" style="background:none;border:none;cursor:pointer;font-size:1rem;line-height:1;padding:0" title="Hide until next version">✕</button>
  </div>
  <script>
    function dismissUpdate(v) {
      var d = new Date(); d.setFullYear(d.getFullYear() + 1)
      document.cookie = 'upd_dismissed=' + encodeURIComponent(v) + ';expires=' + d.toUTCString() + ';path=/'
      var el = document.getElementById('update-banner')
      if (el) el.remove()
    }
  </script>
  {% endif %}

  {% if impersonating %}
  <div style="background:var(--color-warning,#f59e0b);color:#000;padding:.5rem 1rem;text-align:center;font-size:.875rem">
    Viewing as <strong>{{ user.email or user.username }}</strong> (impersonating) —
    <form method="POST" action="/return-to-admin" style="display:inline">
      <button type="submit" style="background:none;border:none;cursor:pointer;font-weight:700;text-decoration:underline">Return to Admin</button>
    </form>
  </div>
  {% endif %}

  <main class="page-content">
    {% if flash and flash.type != 'key' %}
      <div class="container mt-2">
        <div class="alert alert-{{ flash.type }} flash-auto">{{ flash.message }}</div>
      </div>
    {% endif %}

    {% block content %}{% endblock %}
  </main>

  {% if flash and flash.type == 'key' %}
  <div class="key-modal-backdrop" id="key-modal">
    <div class="key-modal">
      <div class="key-modal-icon">🔑</div>
      <h2 class="key-modal-title">{{ flash.label }}</h2>
      <p class="key-modal-sub">{{ flash.sublabel }}</p>
      <div class="key-modal-value">
        <code id="key-value">{{ flash.key }}</code>
      </div>
      <div class="key-modal-actions">
        <button class="btn btn-primary" data-copy-target="key-value" id="copy-key-btn">📋 Copy Key</button>
        <button class="btn btn-ghost" id="dismiss-key-modal">Got it, I've saved it</button>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('dismiss-key-modal').addEventListener('click', function() {
      document.getElementById('key-modal').remove()
    })
    document.getElementById('key-modal').addEventListener('click', function(e) {
      if (e.target === this) this.remove()
    })
  </script>
  {% endif %}

  {% if gdprEnabled and not gdprConsent %}
  <div id="gdpr-banner" style="position:fixed;bottom:0;left:0;right:0;z-index:500;background:var(--bg-surface);border-top:1px solid var(--color-border);padding:.875rem 1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;box-shadow:0 -4px 16px rgba(0,0,0,.2)">
    <p style="margin:0;font-size:.875rem;color:var(--color-text-muted);flex:1;min-width:200px">
      We use cookies and collect visit data (IP address, browser, referrer) to operate this service.
      <a href="/privacy" style="color:var(--color-primary)">Privacy policy</a>
    </p>
    <div style="display:flex;gap:.5rem;flex-shrink:0">
      <button id="gdpr-decline" class="btn btn-ghost btn-sm">Decline</button>
      <button id="gdpr-accept" class="btn btn-primary btn-sm">Accept</button>
    </div>
  </div>
  <script>
    function gdprSetConsent(val) {
      var d = new Date(); d.setFullYear(d.getFullYear() + 1)
      document.cookie = 'gdpr_consent=' + val + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax'
      var b = document.getElementById('gdpr-banner')
      if (b) b.remove()
    }
    document.getElementById('gdpr-accept').addEventListener('click', function(){ gdprSetConsent('accepted') })
    document.getElementById('gdpr-decline').addEventListener('click', function(){ gdprSetConsent('declined') })
  </script>
  {% endif %}

  <footer class="footer">
    <div class="container">
      <p>
        &copy; {{ siteName }} &mdash;
        <a href="/pricing">Pricing</a>
        &nbsp;&bull;&nbsp;
        <a href="/advertise">Advertise</a>
        &nbsp;&bull;&nbsp;
        <a href="{{ githubRepoUrl }}" target="_blank" rel="noopener">Open Source</a>
        &nbsp;&bull;&nbsp;
        <a href="/report">Report a link</a>
        &nbsp;&bull;&nbsp;
        <span class="text-muted" style="font-size:.8rem">v{{ appVersion }}</span>
      </p>
    </div>
  </footer>

  <script src="https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js" defer></script>
  <script src="/static/app.js" defer></script>
  <script>
    // Theme toggle (syncs desktop + hamburger-menu button)
    function applyTheme(t) {
      document.documentElement.setAttribute('data-theme', t)
      localStorage.setItem('theme', t)
      var d = document.getElementById('theme-toggle')
      var m = document.getElementById('theme-toggle-mob')
      if (d) d.textContent = t === 'dark' ? '☀️' : '🌙'
      if (m) m.textContent = (t === 'dark' ? '☀️' : '🌙') + ' Toggle Day / Night'
    }
    var cur = document.documentElement.getAttribute('data-theme') || 'dark'
    applyTheme(cur)
    ;['theme-toggle','theme-toggle-mob'].forEach(function(id){
      var btn = document.getElementById(id)
      if (btn) btn.addEventListener('click', function(){
        applyTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark')
      })
    })

    // Avatar dropdown
    var avatarBtn = document.getElementById('avatar-btn')
    var avatarDrop = document.getElementById('avatar-drop')
    if (avatarBtn && avatarDrop) {
      avatarBtn.addEventListener('click', function(e){ e.stopPropagation(); avatarDrop.classList.toggle('open') })
      document.addEventListener('click', function(){ avatarDrop.classList.remove('open') })
    }

    // New dropdown
    var newBtn = document.getElementById('nav-new-btn')
    var newDrop = document.getElementById('nav-new-drop')
    if (newBtn && newDrop) {
      newBtn.addEventListener('click', function(e){ e.stopPropagation(); newDrop.classList.toggle('open') })
      document.addEventListener('click', function(){ newDrop.classList.remove('open') })
    }

    // Hamburger
    var hamburger = document.getElementById('hamburger-btn')
    var mobileMenu = document.getElementById('nav-mobile-menu')
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', function(e){
        e.stopPropagation()
        var open = mobileMenu.classList.toggle('open')
        hamburger.textContent = open ? '✕' : '☰'
      })
      document.addEventListener('click', function(){
        mobileMenu.classList.remove('open')
        hamburger.textContent = '☰'
      })
    }
  </script>
  {% block scripts %}{% endblock %}
</body>
</html>
