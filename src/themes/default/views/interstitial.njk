{% extends "layouts/base.njk" %}
{% block title %}Redirecting… — {{ siteName }}{% endblock %}
{% block content %}
<section class="section">
  <div class="container" style="max-width:640px;text-align:center">

    {% if ad %}
    <div style="margin-bottom:1.5rem;padding:1rem;background:var(--bg-card);border-radius:var(--radius-lg);border:1px solid var(--color-border)">
      <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-dim);margin-bottom:.5rem">Advertisement</div>
      <a href="{{ ad.clickUrl }}" target="_blank" rel="noopener nofollow sponsored">
        <img src="{{ ad.imageUrl }}" alt="Advertisement" style="max-width:100%;max-height:300px;object-fit:contain;border-radius:4px">
      </a>
    </div>
    {% endif %}

    <div class="card">
      <p class="text-muted text-sm" style="margin:0 0 .5rem">You are being redirected to:</p>
      <p style="word-break:break-all;font-size:.875rem;color:var(--color-text-muted);margin:0 0 1rem;padding:.5rem;background:var(--bg-card);border-radius:var(--radius)">{{ destination }}</p>
      <div style="font-size:2rem;font-weight:700;margin-bottom:.25rem" id="countdown">{{ seconds }}</div>
      <p class="text-muted text-sm" style="margin:0 0 1rem">Redirecting in <span id="cd-label">{{ seconds }}</span> second{{ 's' if seconds != 1 }}…</p>
      <a href="{{ destination }}" class="btn btn-primary btn-sm" id="go-btn">Go now →</a>
    </div>
  </div>
</section>
<script>
  var secs = {{ seconds }};
  var dest = {{ destination | dump | safe }};
  var label = document.getElementById('cd-label');
  var counter = document.getElementById('countdown');
  var timer = setInterval(function() {
    secs--;
    if (label) label.textContent = secs;
    if (counter) counter.textContent = secs;
    if (secs <= 0) {
      clearInterval(timer);
      window.location.href = dest;
    }
  }, 1000);
</script>
{% endblock %}
