{% extends "layouts/base.njk" %}
{% block title %}{{ 'Edit HTML Paste' if editCode else 'HTML Paste' }} — {{ siteName }}{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://unpkg.com/jodit@4/es2021/jodit.min.css">
<style>
  .jodit-container { border-radius: var(--radius) !important; overflow: hidden; }
  .jodit-workplace { background: var(--bg-input) !important; }
</style>
{% endblock %}

{% block content %}
<section class="section">
  <div class="container" style="max-width:900px">
    <h1 class="section-title">{{ 'Edit HTML Paste' if editCode else 'HTML Paste' }}</h1>
    {% if not editCode %}<p class="section-subtitle">Share HTML snippets or full pages. Rendered in a sandboxed frame.</p>{% endif %}

    {% if error %}<div class="alert alert-error mb-3">{{ error }}</div>{% endif %}

    <div class="card">
      <form method="POST" action="{{ '/h/' + editCode + '/edit' if editCode else '/h' }}" id="html-paste-form">
        <div class="form-group">
          <label class="label" for="title">Title <span class="text-muted">(optional)</span></label>
          <input id="title" type="text" name="title" class="input" value="{{ title }}" placeholder="Untitled HTML">
        </div>
        <div class="form-group">
          <label class="label" for="content">HTML Content</label>
          <textarea id="content" name="content" required>{{ content }}</textarea>
        </div>
        {% if not editCode %}
        <div style="border-top:1px solid var(--color-border);margin-top:1rem;padding-top:.75rem;display:flex;flex-direction:column;gap:.5rem">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" name="burn_on_read" value="1"> 🔥 Burn on read (delete after first view)
          </label>
          {% if user %}
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" name="is_private" value="1" {% if isPrivate %}checked{% endif %}> 🔒 Private (only visible to you)
          </label>
          {% endif %}
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;flex-wrap:wrap">
            <span>⏰ Expires:</span>
            <input type="datetime-local" name="expires_at" class="input" style="flex:1;min-width:200px;max-width:280px" id="html-expires">
            <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('html-expires').value=''">Clear</button>
          </label>
        </div>
        {% else %}
        {% if user %}
        <div class="form-group" style="margin-top:1rem">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" name="is_private" value="1" {% if isPrivate %}checked{% endif %}> Private
          </label>
        </div>
        {% endif %}
        {% endif %}
        <div style="display:flex;gap:.75rem;margin-top:1rem">
          {% if editCode %}
          <a href="/{{ editCode }}" class="btn btn-ghost">Cancel</a>
          {% endif %}
          <button type="submit" class="btn btn-primary{% if not editCode %} btn-block{% endif %}">{{ 'Update HTML Paste' if editCode else 'Create HTML Paste' }}</button>
        </div>
      </form>
    </div>
    {% include "partials/ad-banner.njk" %}
  </div>
</section>
{% endblock %}

{% block scripts %}
<script src="https://unpkg.com/jodit@4/es2021/jodit.min.js"></script>
<script>
(function () {
  var isDark = document.documentElement.getAttribute('data-theme') !== 'light'
  var editor = Jodit.make('#content', {
    theme: isDark ? 'dark' : 'default',
    defaultMode: Jodit.MODE_SOURCE,
    height: 500,
    language: 'en',
    buttons: [
      'source', '|',
      'bold', 'italic', 'underline', 'strikethrough', '|',
      'ul', 'ol', '|',
      'outdent', 'indent', '|',
      'font', 'fontsize', 'brush', '|',
      'link', 'image', '|',
      'align', '|',
      'hr', 'table', '|',
      'undo', 'redo', '|',
      'fullsize',
    ],
    toolbarAdaptive: false,
    spellcheck: false,
    showCharsCounter: false,
    showWordsCounter: false,
    showXPathInStatusbar: false,
  })

  // Keep Jodit theme in sync if user toggles day/night while on this page
  var obs = new MutationObserver(function () {
    var dark = document.documentElement.getAttribute('data-theme') !== 'light'
    editor.setTheme(dark ? 'dark' : 'default')
  })
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] })
})()
</script>
{% endblock %}
