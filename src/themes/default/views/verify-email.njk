{% extends "layouts/base.njk" %}
{% block title %}Email Verification — {{ siteName }}{% endblock %}
{% block content %}
<div class="auth-wrap">
  <div class="auth-card">
    <h1 class="auth-title">Email verification</h1>

    {% if error %}
    <div class="alert alert-error mb-3">{{ error }}</div>
    <p class="text-center text-sm text-muted mt-3">
      <a href="/resend-verification">Request a new verification link</a>
    </p>
    {% endif %}
  </div>
</div>
{% endblock %}
