{% extends "layouts/base.njk" %}
{% block title %}{{ 'Edit Paste' if editCode else 'Text Paste' }} — {{ siteName }}{% endblock %}
{% block content %}
<section class="section">
  <div class="container" style="max-width:720px">
    <h1 class="section-title">{{ 'Edit Paste' if editCode else 'Text Paste' }}</h1>

    {% if error %}<div class="alert alert-error mb-3" id="form-error">{{ error }}</div>{% endif %}

    {# Inline success panel (shown by JS after encrypted paste creation) #}
    <div id="enc-success" class="card" style="display:none;padding:1.5rem;text-align:center">
      <div style="font-size:2rem;margin-bottom:.5rem">🔐</div>
      <h2 style="margin:0 0 .5rem;font-size:1.1rem">Encrypted paste created</h2>
      <p class="text-muted text-sm" style="margin:0 0 1rem">
        The decryption key is embedded in the link below. Anyone with this link can read the paste.
        The key is <strong>never sent to the server</strong>.
      </p>
      <div style="background:var(--bg-input);border:1px solid var(--color-border);border-radius:var(--radius);padding:.75rem 1rem;font-family:monospace;font-size:.85rem;word-break:break-all;margin-bottom:1rem" id="enc-url"></div>
      <div style="display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap">
        <button class="btn btn-primary" id="enc-copy-btn">📋 Copy Link</button>
        <a id="enc-visit-btn" href="#" class="btn btn-secondary" target="_blank" rel="noopener">↗ Visit</a>
        <a href="/t" class="btn btn-ghost">+ New paste</a>
      </div>
    </div>

    <div class="card" id="paste-form-card">
      <form method="POST" action="{{ '/t/' + editCode + '/edit' if editCode else '/t' }}" id="paste-form">
        <div class="form-group">
          <label class="label" for="title">Title <span class="text-muted">(optional)</span></label>
          <input id="title" type="text" name="title" class="input" value="{{ title }}" placeholder="Untitled paste">
        </div>
        <div class="form-group">
          <label class="label" for="content">Content</label>
          <textarea id="content" name="content" class="input" rows="16" required autofocus
            style="font-family:monospace;resize:vertical">{{ content }}</textarea>
        </div>

        {% if not editCode %}
        <div style="border-top:1px solid var(--color-border);margin:.75rem 0;padding-top:.75rem;display:flex;flex-direction:column;gap:.5rem">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" id="encrypt-toggle" name="is_encrypted" value="1"> 🔐 Client-side encryption (key stays in URL, never sent to server)
          </label>
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" id="burn-toggle" name="burn_on_read" value="1"> 🔥 Burn on read (delete after first view)
          </label>
          {% if user %}
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" name="is_private" value="1" {% if isPrivate %}checked{% endif %}> 🔒 Private (only visible to you)
          </label>
          {% endif %}
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;flex-wrap:wrap">
            <span>⏰ Expires:</span>
            <input type="datetime-local" id="expires-input" name="expires_at" class="input" style="flex:1;min-width:200px;max-width:280px">
            <button type="button" class="btn btn-ghost btn-sm" id="clear-expiry">Clear</button>
          </label>
        </div>
        {% else %}
        {% if user %}
        <div class="form-group">
          <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
            <input type="checkbox" name="is_private" value="1" {% if isPrivate %}checked{% endif %}> Private (only visible to you)
          </label>
        </div>
        {% endif %}
        {% endif %}

        <div style="display:flex;gap:.75rem">
          {% if editCode %}
          <a href="/{{ editCode }}" class="btn btn-ghost">Cancel</a>
          {% endif %}
          <button type="submit" id="submit-btn" class="btn btn-primary{% if not editCode %} btn-block{% endif %}">{{ 'Update Paste' if editCode else 'Create Paste' }}</button>
        </div>
      </form>
    </div>
    {% include "partials/ad-banner.njk" %}
  </div>
</section>
{% endblock %}

{% block scripts %}
{% if not editCode %}
<script>
(function () {
  var encToggle = document.getElementById('encrypt-toggle')
  var burnToggle = document.getElementById('burn-toggle')
  var expiresInput = document.getElementById('expires-input')
  var clearExpiry = document.getElementById('clear-expiry')
  var form = document.getElementById('paste-form')
  var formCard = document.getElementById('paste-form-card')
  var successPanel = document.getElementById('enc-success')
  var encUrl = document.getElementById('enc-url')
  var encCopyBtn = document.getElementById('enc-copy-btn')
  var encVisitBtn = document.getElementById('enc-visit-btn')
  var submitBtn = document.getElementById('submit-btn')
  var formError = document.getElementById('form-error')

  clearExpiry.addEventListener('click', function () { expiresInput.value = '' })

  // ── Web Crypto helpers ──────────────────────────────────────────

  async function generateKey() {
    return crypto.subtle.generateKey({ name: 'AES-GCM', length: 256 }, true, ['encrypt', 'decrypt'])
  }

  async function encryptText(plaintext, key) {
    var iv = crypto.getRandomValues(new Uint8Array(12))
    var encoded = new TextEncoder().encode(plaintext)
    var ciphertext = await crypto.subtle.encrypt({ name: 'AES-GCM', iv: iv }, key, encoded)
    var combined = new Uint8Array(12 + ciphertext.byteLength)
    combined.set(iv)
    combined.set(new Uint8Array(ciphertext), 12)
    return btoa(String.fromCharCode.apply(null, combined))
  }

  async function exportKeyBase64url(key) {
    var raw = await crypto.subtle.exportKey('raw', key)
    var bytes = new Uint8Array(raw)
    return btoa(String.fromCharCode.apply(null, bytes))
      .replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '')
  }

  // ── Encrypted form submit ───────────────────────────────────────

  form.addEventListener('submit', async function (e) {
    if (!encToggle.checked) return // Let normal form submit proceed

    e.preventDefault()

    var content = document.getElementById('content').value
    if (!content.trim()) {
      showError('Content cannot be empty.')
      return
    }

    submitBtn.disabled = true
    submitBtn.textContent = 'Encrypting…'

    try {
      var key = await generateKey()
      var encrypted = await encryptText(content, key)
      var keyB64 = await exportKeyBase64url(key)

      var params = new URLSearchParams()
      params.append('content', encrypted)
      params.append('title', document.getElementById('title').value)
      params.append('is_encrypted', '1')
      if (burnToggle.checked) params.append('burn_on_read', '1')
      if (expiresInput.value) params.append('expires_at', expiresInput.value)

      var res = await fetch('/t', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
        body: params.toString()
      })

      if (!res.ok) {
        var err = await res.json().catch(function () { return { error: 'Server error.' } })
        showError(err.error || 'Failed to create paste.')
        submitBtn.disabled = false
        submitBtn.textContent = 'Create Paste'
        return
      }

      var data = await res.json()
      var fullUrl = location.protocol + '//' + location.host + '/' + data.code + '#key=' + keyB64

      encUrl.textContent = fullUrl
      encVisitBtn.href = fullUrl
      encCopyBtn.onclick = function () {
        navigator.clipboard.writeText(fullUrl).then(function () {
          encCopyBtn.textContent = '✓ Copied!'
          setTimeout(function () { encCopyBtn.textContent = '📋 Copy Link' }, 2000)
        })
      }

      formCard.style.display = 'none'
      successPanel.style.display = 'block'
    } catch (err) {
      showError('Encryption failed: ' + err.message)
      submitBtn.disabled = false
      submitBtn.textContent = 'Create Paste'
    }
  })

  function showError(msg) {
    var el = formError || document.createElement('div')
    el.id = 'form-error'
    el.className = 'alert alert-error mb-3'
    el.textContent = msg
    if (!formError) {
      formCard.insertBefore(el, formCard.firstChild)
      formError = el
    }
    el.style.display = 'block'
  }
})()
</script>
{% endif %}
{% endblock %}
