{% extends "layouts/base.njk" %}
{% block title %}Pricing — {{ siteName }}{% endblock %}

{% block content %}
<div class="container" style="max-width:960px">
  <div class="page-header" style="text-align:center;display:block;margin-bottom:2rem">
    <h1 class="page-title">Plans &amp; Pricing</h1>
    <p class="page-subtitle">Choose the plan that works for you.</p>
  </div>

  {% if flash %}
  <div class="alert alert-{{ flash.type }}" style="margin-bottom:1.5rem">{{ flash.message }}</div>
  {% endif %}

  {% include "partials/ad-banner.njk" %}

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;align-items:start">

    {% for tier in tiers %}
    {% set isCurrent = currentTier == tier.name %}

    <div class="card" style="position:relative;border:{{ '2px solid var(--color-primary)' if isCurrent else '1px solid var(--color-border)' }}">

      {% if isCurrent %}
      <div style="position:absolute;top:-1px;right:1rem;background:var(--color-primary);color:#fff;font-size:.7rem;font-weight:700;padding:2px 10px;border-radius:0 0 6px 6px;text-transform:uppercase;letter-spacing:.05em">Current Plan</div>
      {% endif %}

      {# Header #}
      <div style="margin-bottom:1.25rem">
        <h2 style="margin:0 0 .5rem;font-size:1.25rem">{{ tier.label or tier.name }}</h2>

        {% if tier.price > 0 %}
          {% set yearlyPrice = tier.price_yearly if tier.price_yearly > 0 else (tier.price * 12) %}
          <div style="display:flex;gap:1.5rem;align-items:baseline;flex-wrap:wrap;margin:.5rem 0">
            <div>
              <span style="font-size:1.6rem;font-weight:700">${{ tier.price }}</span>
              <span style="font-size:.875rem;color:var(--color-text-muted)">/mo</span>
            </div>
            <div>
              <span style="font-size:1.6rem;font-weight:700">${{ yearlyPrice }}</span>
              <span style="font-size:.875rem;color:var(--color-text-muted)">/yr</span>
              {% if tier.price_yearly > 0 and tier.price_yearly < (tier.price * 12) %}
              <span style="font-size:.75rem;color:var(--color-success,#16a34a);font-weight:600;margin-left:.3rem">Save ${{ (tier.price * 12 - tier.price_yearly) | round(2) }}</span>
              {% endif %}
            </div>
          </div>
        {% else %}
          <div style="font-size:1.75rem;font-weight:700;margin:.5rem 0">Free</div>
        {% endif %}

        {% if tier.description %}
        <p style="font-size:.875rem;color:var(--color-text-muted);margin:.5rem 0 0">{{ tier.description }}</p>
        {% endif %}
      </div>

      {% include "partials/tier-features.njk" %}

      {# CTA buttons #}
      {% if tier.price > 0 %}
        {% if user %}
          {% if isCurrent %}
            <form method="POST" action="/stripe/portal">
              <button class="btn btn-secondary btn-block">Manage Subscription</button>
            </form>
          {% else %}
            <div style="display:flex;gap:.5rem">
              <form method="POST" action="/stripe/checkout" style="flex:1">
                <input type="hidden" name="tier" value="{{ tier.name }}">
                <input type="hidden" name="interval" value="monthly">
                <button class="btn btn-primary btn-block">Monthly</button>
              </form>
              <form method="POST" action="/stripe/checkout" style="flex:1">
                <input type="hidden" name="tier" value="{{ tier.name }}">
                <input type="hidden" name="interval" value="yearly">
                <button class="btn btn-secondary btn-block">Yearly</button>
              </form>
            </div>
          {% endif %}
        {% else %}
          <a href="/register" class="btn btn-primary btn-block">Get Started</a>
        {% endif %}
      {% else %}
        {% if user %}
          {% if isCurrent %}
            <button class="btn btn-secondary btn-block" disabled>Current Plan</button>
          {% else %}
            <form method="POST" action="/pricing/change">
              <input type="hidden" name="tier" value="{{ tier.name }}">
              {% if subscriptionInterval %}
              <p class="text-xs text-muted mb-2" style="line-height:1.4">⚠ Switching to Free will not cancel your active subscription or issue a refund. To stop future charges, cancel via <strong>Manage Subscription</strong> first.</p>
              {% endif %}
              <button class="btn btn-secondary btn-block" data-confirm="{% if subscriptionInterval %}Switching to Free will not cancel your Stripe subscription or issue a refund for unused time. To cancel billing, use Manage Subscription instead. Switch anyway?{% else %}Switch to {{ tier.label or tier.name }} plan?{% endif %}">Switch to {{ tier.label or tier.name }}</button>
            </form>
          {% endif %}
        {% else %}
          <a href="/register" class="btn btn-primary btn-block">Get Started Free</a>
        {% endif %}
      {% endif %}

    </div>
    {% endfor %}

    {% if not tiers.length %}
    <div class="card text-center text-muted" style="padding:2rem;grid-column:1/-1">No plans configured yet.</div>
    {% endif %}
  </div>

  {% if user and user.role == 'admin' %}
  <div style="margin-top:2rem;text-align:center;font-size:.8rem;color:var(--color-text-muted)">
    <a href="/admin/account-tiers">Manage tiers in Admin →</a>
  </div>
  {% endif %}
</div>
{% endblock %}
