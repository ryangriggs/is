{% extends "layouts/base.njk" %}
{% block title %}{{ link.title or 'Untitled Paste' }} — {{ siteName }}{% endblock %}
{% block content %}
<section class="section">
  <div class="container" style="max-width:800px">
    {% include "partials/ad-banner.njk" %}
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1rem">
      <div>
        <h1 style="margin:0;font-size:1.25rem">
          {{ link.title or 'Untitled Paste' }}
          {% if link.is_encrypted %}<span title="Client-side encrypted" style="font-size:.85rem">🔐</span>{% endif %}
          {% if link.burn_on_read %}<span title="Burned — this was a one-time view" style="font-size:.85rem">🔥</span>{% endif %}
        </h1>
        <p class="text-muted text-sm" style="margin:.25rem 0 0">
          {{ link.created_at | date }} &bull;
          <a href="/report/{{ link.code }}" class="text-muted">Report</a>
        </p>
      </div>
      <div style="display:flex;gap:.5rem">
        {% if not link.is_encrypted %}
        <button class="btn btn-secondary btn-sm" data-copy-target="paste-content">📋 Copy</button>
        {% else %}
        <button class="btn btn-secondary btn-sm" id="copy-decrypted">📋 Copy</button>
        {% endif %}
        {% if user and user.id == link.owner_id and not link.is_encrypted %}
        <a href="/t/{{ link.code }}/edit" class="btn btn-ghost btn-sm">✏️ Edit</a>
        {% endif %}
        <a href="/t" class="btn btn-ghost btn-sm">+ New paste</a>
      </div>
    </div>

    {% if link.is_encrypted %}
    {# Encrypted paste — content decrypted client-side using key from URL fragment #}
    <div id="dec-loading" class="card" style="padding:2rem;text-align:center;color:var(--color-text-muted)">
      🔐 Decrypting…
    </div>

    {# Shown when no key is in the fragment — key never submitted to server #}
    <div id="dec-key-prompt" class="card" style="display:none;padding:1.5rem">
      <p style="margin:0 0 .75rem;font-weight:600">🔐 Decryption key required</p>
      <p class="text-muted text-sm" style="margin:0 0 1rem">
        This paste is end-to-end encrypted. Paste the decryption key below — it is used locally in your browser and never sent to the server.
      </p>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap">
        <input id="dec-key-input" type="text" class="input" style="flex:1;min-width:200px;font-family:monospace;font-size:.85rem"
          placeholder="Paste key here…" autocomplete="off" spellcheck="false">
        <button id="dec-key-submit" class="btn btn-primary">Decrypt</button>
      </div>
      <div id="dec-key-error" class="text-sm" style="display:none;margin-top:.5rem;color:#dc2626">
        Incorrect key or corrupted data. Please check and try again.
      </div>
    </div>

    <div id="dec-error" class="alert alert-error" style="display:none">
      <strong>Decryption failed.</strong> The key may be incorrect or the data is corrupted.
    </div>
    <div class="card" id="dec-content-wrap" style="display:none;padding:0;overflow:hidden">
      <pre id="paste-content" style="margin:0;padding:1.5rem;overflow-x:auto;white-space:pre-wrap;word-break:break-word"></pre>
    </div>
    {% else %}
    <div class="card" style="padding:0;overflow:hidden">
      <pre id="paste-content" style="margin:0;padding:1.5rem;overflow-x:auto;white-space:pre-wrap;word-break:break-word">{{ link.destination }}</pre>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}

{% block scripts %}
{% if link.is_encrypted %}
<script>
(function () {
  var loading    = document.getElementById('dec-loading')
  var keyPrompt  = document.getElementById('dec-key-prompt')
  var keyInput   = document.getElementById('dec-key-input')
  var keySubmit  = document.getElementById('dec-key-submit')
  var keyError   = document.getElementById('dec-key-error')
  var errorEl    = document.getElementById('dec-error')
  var contentWrap = document.getElementById('dec-content-wrap')
  var pre        = document.getElementById('paste-content')
  var copyBtn    = document.getElementById('copy-decrypted')

  // Ciphertext stored server-side — no secret here
  var cipherB64 = {{ link.destination | dump | safe }}

  async function importKeyBase64url(b64url) {
    var b64 = b64url.trim().replace(/-/g, '+').replace(/_/g, '/')
    var pad = (4 - b64.length % 4) % 4
    b64 += '==='.slice(0, pad)
    var bytes = Uint8Array.from(atob(b64), function (c) { return c.charCodeAt(0) })
    // Key is imported into the Web Crypto API — it never leaves this function as raw bytes
    return crypto.subtle.importKey('raw', bytes, { name: 'AES-GCM' }, false, ['decrypt'])
  }

  async function decryptWithKey(keyB64url) {
    var key = await importKeyBase64url(keyB64url)
    var bytes = Uint8Array.from(atob(cipherB64), function (c) { return c.charCodeAt(0) })
    var iv = bytes.slice(0, 12)
    var ciphertext = bytes.slice(12)
    // Decryption happens entirely in the browser via SubtleCrypto
    var plaintext = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: iv }, key, ciphertext)
    return new TextDecoder().decode(plaintext)
  }

  function showContent(plaintext) {
    pre.textContent = plaintext
    loading.style.display = 'none'
    keyPrompt.style.display = 'none'
    contentWrap.style.display = 'block'
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(plaintext).then(function () {
          copyBtn.textContent = '✓ Copied!'
          setTimeout(function () { copyBtn.textContent = '📋 Copy' }, 2000)
        })
      })
    }
  }

  async function tryDecrypt(keyB64url) {
    try {
      var plaintext = await decryptWithKey(keyB64url)
      showContent(plaintext)
    } catch (_) {
      loading.style.display = 'none'
      errorEl.style.display = 'block'
    }
  }

  // On load: check URL fragment for key — fragment is never sent to the server
  var hash = window.location.hash.slice(1)
  var params = new URLSearchParams(hash)
  var keyB64url = params.get('key')

  if (keyB64url) {
    tryDecrypt(keyB64url)
  } else {
    // No key in fragment — show manual entry box; key stays in browser only
    loading.style.display = 'none'
    keyPrompt.style.display = 'block'
    keyInput.focus()
  }

  // Manual key entry — never submitted to server, used only in-browser
  async function handleManualKey() {
    var raw = keyInput.value.trim()
    if (!raw) return
    keyError.style.display = 'none'
    keySubmit.disabled = true
    keySubmit.textContent = 'Decrypting…'
    try {
      var plaintext = await decryptWithKey(raw)
      showContent(plaintext)
    } catch (_) {
      keyError.style.display = 'block'
      keySubmit.disabled = false
      keySubmit.textContent = 'Decrypt'
    }
  }

  keySubmit.addEventListener('click', handleManualKey)
  keyInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') handleManualKey()
  })
})()
</script>
{% endif %}
{% endblock %}
