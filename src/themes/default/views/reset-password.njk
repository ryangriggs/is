{% extends "layouts/base.njk" %}
{% block title %}Set New Password — {{ siteName }}{% endblock %}
{% block content %}
<div class="auth-wrap">
  <div class="auth-card">
    <h1 class="auth-title">Set new password</h1>

    {% if error %}
    <div class="alert alert-error mb-3">{{ error }}</div>
    {% endif %}

    <form method="POST" action="/reset-password">
      <input type="hidden" name="token" value="{{ token }}">
      <div class="form-group">
        <label class="label" for="password">New Password</label>
        <input id="password" type="password" name="password" class="input"
          required minlength="8" autocomplete="new-password" autofocus>
        <p class="text-xs text-muted mt-1">At least 8 characters.</p>
      </div>
      <div class="form-group">
        <label class="label" for="password2">Confirm Password</label>
        <input id="password2" type="password" name="password2" class="input"
          required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Set Password</button>
    </form>
  </div>
</div>
{% endblock %}
