{% extends "layouts/base.njk" %}
{% block title %}Profile — {{ siteName }}{% endblock %}
{% block content %}
<div class="container" style="max-width:540px;padding-top:2rem">
  <div class="page-header">
    <h1 class="page-title">My Profile</h1>
  </div>

  {% include "partials/ad-banner.njk" %}
  <form method="POST" action="/profile" class="card">
    <h2 style="font-size:1rem;font-weight:600;margin:0 0 1.25rem">Account Details</h2>

    <div class="form-group">
      <label class="label">Display Name</label>
      <input type="text" name="display_name" class="input"
        value="{{ profileUser.display_name or '' }}" placeholder="Your name">
    </div>

    <div class="form-group">
      <label class="label">Email Address</label>
      <input type="email" name="email" class="input"
        value="{{ profileUser.email or '' }}" required>
    </div>

    <hr style="border:none;border-top:1px solid var(--color-border);margin:1.5rem 0">
    {% if profileUser.password_hash %}
    <h2 style="font-size:1rem;font-weight:600;margin:0 0 1rem">Change Password</h2>
    <p class="text-sm text-muted" style="margin-bottom:1rem">Leave blank to keep your current password.</p>
    <div class="form-group">
      <label class="label">Current Password</label>
      <input type="password" name="current_password" class="input" autocomplete="current-password">
    </div>
    {% else %}
    <h2 style="font-size:1rem;font-weight:600;margin:0 0 1rem">Set a Password</h2>
    <p class="text-sm text-muted" style="margin-bottom:1rem">Add a password as a fallback login method alongside Google.</p>
    {% endif %}
    <div class="form-group">
      <label class="label">New Password</label>
      <input type="password" name="new_password" class="input" autocomplete="new-password" minlength="8">
    </div>
    <div class="form-group">
      <label class="label">Confirm New Password</label>
      <input type="password" name="new_password2" class="input" autocomplete="new-password">
    </div>

    <button type="submit" class="btn btn-primary btn-block">Save Changes</button>
  </form>

  <div class="card mt-3">
    <h2 style="font-size:1rem;font-weight:600;margin:0 0 1rem">Linked Accounts</h2>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem">
      <div style="display:flex;align-items:center;gap:.6rem">
        <svg width="20" height="20" viewBox="0 0 18 18" aria-hidden="true"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z"/></svg>
        <span><strong>Google</strong></span>
        {% if profileUser.google_id %}
          <span class="badge badge-success">Connected</span>
        {% else %}
          <span class="badge badge-neutral">Not connected</span>
        {% endif %}
      </div>
      <div style="display:flex;gap:.5rem;align-items:center">
        {% if profileUser.google_id %}
          {% if profileUser.password_hash %}
          <form method="POST" action="/profile/unlink-google" style="margin:0"
            onsubmit="return confirm('Unlink Google? You will need to use your password to log in going forward.')">
            <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--color-danger)">Unlink</button>
          </form>
          {% else %}
          <span class="text-sm text-muted">Set a password below before unlinking</span>
          {% endif %}
        {% else %}
          <a href="/auth/google/link" class="btn btn-secondary btn-sm">Connect Google</a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="card mt-3">
    <h2 style="font-size:1rem;font-weight:600;margin:0 0 1rem">Subscription</h2>

    <div style="display:flex;flex-direction:column;gap:.6rem">

      {# Plan name + status #}
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem">
        <div>
          <span style="font-weight:600">{{ tierInfo.label or (profileUser.subscription_tier | capitalize) or 'Free' }}</span>
          {% if profileUser.stripe_subscription_status %}
            {% if profileUser.stripe_subscription_status == 'active' %}
              <span class="badge badge-success" style="margin-left:.4rem">Active</span>
            {% elif profileUser.stripe_subscription_status == 'trialing' %}
              <span class="badge badge-info" style="margin-left:.4rem">Trial</span>
            {% elif profileUser.stripe_subscription_status == 'past_due' %}
              <span class="badge badge-warning" style="margin-left:.4rem">Past Due</span>
            {% elif profileUser.stripe_subscription_status == 'canceled' or profileUser.stripe_subscription_status == 'cancelled' %}
              <span class="badge badge-danger" style="margin-left:.4rem">Canceled</span>
            {% else %}
              <span class="badge badge-neutral" style="margin-left:.4rem">{{ profileUser.stripe_subscription_status }}</span>
            {% endif %}
          {% endif %}
        </div>

        {# Price #}
        {% if tierInfo and tierInfo.price > 0 %}
          {% if profileUser.stripe_subscription_interval == 'yearly' %}
            {% set displayPrice = tierInfo.price_yearly if tierInfo.price_yearly > 0 else (tierInfo.price * 12) %}
            <span style="font-size:.95rem;font-weight:600">${{ displayPrice }}<span style="font-weight:400;color:var(--color-text-muted);font-size:.8rem">/yr</span></span>
          {% else %}
            <span style="font-size:.95rem;font-weight:600">${{ tierInfo.price }}<span style="font-weight:400;color:var(--color-text-muted);font-size:.8rem">/mo</span></span>
          {% endif %}
        {% elif not profileUser.stripe_subscription_status %}
          <span style="font-size:.95rem;font-weight:600">Free</span>
        {% endif %}
      </div>

      {# Billing cycle + renewal #}
      {% if profileUser.stripe_subscription_interval %}
      <div class="text-sm text-muted">
        Billing: <strong>{{ profileUser.stripe_subscription_interval | capitalize }}</strong>
        {% if profileUser.stripe_current_period_end %}
          &nbsp;·&nbsp;
          {% if profileUser.stripe_subscription_status == 'canceled' or profileUser.stripe_subscription_status == 'cancelled' %}
            Access until {{ profileUser.stripe_current_period_end | date }}
          {% else %}
            Renews {{ profileUser.stripe_current_period_end | date }}
          {% endif %}
        {% endif %}
      </div>
      {% endif %}

      {# Member since #}
      <div class="text-sm text-muted">Member since {{ profileUser.created_at | date }}</div>

    </div>

    <div style="margin-top:1rem;display:flex;gap:.5rem;flex-wrap:wrap;align-items:center">
      {% if profileUser.stripe_subscription_status %}
      <form method="POST" action="/stripe/portal" style="margin:0">
        <button class="btn btn-secondary btn-sm">Manage Subscription</button>
      </form>
      {% endif %}
      <a href="/pricing" class="btn btn-ghost btn-sm">View Plans</a>
    </div>
  </div>
</div>
{% endblock %}
